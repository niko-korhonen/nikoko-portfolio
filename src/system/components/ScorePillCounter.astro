---
import { accentContainerTokens, accentTokenCssVar } from '../accent-tokens';

export type ScorePillCounterVariant = 'primary' | 'secondary' | 'ghost' | 'accent';
export type ScorePillCounterSize = 'l' | 'm' | 's';

type AccentTok = (typeof accentContainerTokens)[number];

interface Props {
  variant?: ScorePillCounterVariant;
  size?: ScorePillCounterSize;
  /** Non-negative integer; displayed and animated on the client via `setScorePillValue`. */
  value?: number;
  leadingLabel?: string;
  trailingLabel?: string;
  /** When variant is accent, picks the container token (default: blue). */
  accentContainer?: AccentTok;
  class?: string;
  id?: string;
}

const {
  variant = 'primary',
  size = 'm',
  value = 0,
  leadingLabel = '',
  trailingLabel = '',
  accentContainer = 'container-accent-blue',
  class: className = '',
  id: idAttr,
} = Astro.props;

const typoClass =
  size === 'l' ? 'text-label-m-plain' : size === 's' ? 'text-label-xs-plain' : 'text-label-s-plain';

const displayValue = Math.max(0, Math.floor(Number.isFinite(value) ? value : 0));

const rootClass = ['ui-btn', 'ui-score-pill', typoClass, className].filter(Boolean).join(' ');

const accentStyle = variant === 'accent' ? `background: ${accentTokenCssVar(accentContainer)};` : undefined;

const ariaParts: string[] = [];
if (leadingLabel.trim()) ariaParts.push(leadingLabel.trim());
ariaParts.push(String(displayValue));
if (trailingLabel.trim()) ariaParts.push(trailingLabel.trim());
const ariaLabel = ariaParts.join(' ');
---

<span
  class={rootClass}
  id={idAttr}
  data-variant={variant}
  data-size={size}
  data-ui-score-pill
  data-value={displayValue}
  role="status"
  aria-live="polite"
  aria-atomic="true"
  aria-label={ariaLabel}
  {...accentStyle ? { style: accentStyle } : {}}
>
  <span class="ui-btn__icon">
    <slot name="icon-start" />
  </span>
  <span class="ui-btn__label ui-score-pill__label">
    {leadingLabel.trim() ? <span class="ui-score-pill__leading">{leadingLabel}</span> : null}
    <span class="ui-score-pill__value">
      <span class="ui-score-pill__value-window">
        <span class="ui-score-pill__value-track">
          <span class="ui-score-pill__digit">{displayValue}</span>
        </span>
      </span>
    </span>
    {trailingLabel.trim() ? <span class="ui-score-pill__trailing">{trailingLabel}</span> : null}
  </span>
  <span class="ui-btn__icon" aria-hidden="true"></span>
</span>
