---
export type ItemVariant = 'floating' | 'inline';

interface Props {
  variant?: ItemVariant;
  description?: string;
  detail?: string;
  class?: string;
}

const {
  variant = 'floating',
  description,
  detail,
  class: className = '',
} = Astro.props;

const itemClass = ['ui-item-static', className].filter(Boolean).join(' ');

const hasSlotStart = Astro.slots.has('slot-start');
const hasSlotEnd = Astro.slots.has('slot-end');
const showTrailing = Boolean(detail) || hasSlotEnd;
---

<div class={itemClass} data-variant={variant}>
  <div class="ui-item__row">
    {hasSlotStart ? (
      <span class="ui-item__slot-start">
        <slot name="slot-start" />
      </span>
    ) : null}
    <span class="ui-item__text">
      <span class="ui-item__label text-label-s-plain">
        <slot />
      </span>
      {description ? <span class="ui-item__description text-body-s-plain">{description}</span> : null}
    </span>
    {showTrailing ? (
      <span class="ui-item__trailing">
        {detail ? <span class="ui-item__detail text-body-s-plain">{detail}</span> : null}
        {hasSlotEnd ? (
          <span class="ui-item__slot-end">
            <slot name="slot-end" />
          </span>
        ) : null}
      </span>
    ) : null}
  </div>
</div>
