---
import { randomUUID } from 'node:crypto';

export type TextFieldVariant = 'filled' | 'outlined';
export type TextFieldTone = 'default' | 'error' | 'success';
export type TextFieldSize = 'l' | 'm';

interface Props {
  variant?: TextFieldVariant;
  tone?: TextFieldTone;
  size?: TextFieldSize;
  /** Visible label (inside the control when set). Use with <slot name="label" /> as alternative. */
  label?: string;
  /** Required when there is no visible label (accessibility). */
  ariaLabel?: string;
  id?: string;
  name?: string;
  placeholder?: string;
  value?: string;
  disabled?: boolean;
  multiline?: boolean;
  rows?: number;
  type?: 'text' | 'search' | 'email' | 'password' | 'url' | 'tel';
  class?: string;
  /** Helper text below the field. Prefer over slot when plain string is enough. */
  description?: string;
  /**
   * Single-line fields with a visible label default to a floating label.
   * Set to false for a stacked label above the input.
   */
  floatingLabel?: boolean;
  /** Hint for autofill / password managers; omit for default browser behavior. */
  autocomplete?: string;
  /** iOS Safari: reduces unwanted correction suggestions (non-standard). */
  autocorrect?: string;
  autocapitalize?: string;
  spellcheck?: boolean;
  enterkeyhint?: string;
}

const {
  variant = 'filled',
  tone = 'default',
  size = 'l',
  label = '',
  ariaLabel,
  id: idProp,
  name,
  placeholder,
  value,
  disabled = false,
  multiline = false,
  rows = 3,
  type = 'text',
  class: className = '',
  description = '',
  floatingLabel: floatingLabelProp,
  autocomplete,
  autocorrect,
  autocapitalize,
  spellcheck,
  enterkeyhint,
} = Astro.props;

const mobileInputAttrs = {
  ...(autocomplete !== undefined ? { autocomplete } : {}),
  ...(autocorrect !== undefined ? { autocorrect } : {}),
  ...(autocapitalize !== undefined ? { autocapitalize } : {}),
  ...(spellcheck !== undefined ? { spellcheck } : {}),
  ...(enterkeyhint !== undefined ? { enterkeyhint } : {}),
};

const hasLabelSlot = Astro.slots.has('label');
const hasDescriptionSlot = Astro.slots.has('description');
const hasDescriptionIconSlot = Astro.slots.has('description-icon');
const hasLabel = Boolean(label?.trim()) || hasLabelSlot;
const hasHelper =
  Boolean(description?.trim()) || hasDescriptionSlot || hasDescriptionIconSlot;

if (!hasLabel && !ariaLabel && import.meta.env.DEV) {
  console.warn('[TextField] Pass ariaLabel when no visible label is provided.');
}

const id = idProp ?? `tf-${randomUUID()}`;
const helperId = `${id}-helper`;

/** Single-line labeled fields use a floating label; :placeholder-shown needs a placeholder token. */
const floatingPlaceholder =
  hasLabel && !multiline ? (placeholder !== undefined && placeholder !== '' ? placeholder : ' ') : placeholder;

const rootClass = ['ui-field', className].filter(Boolean).join(' ');
const useFloatingLabel =
  floatingLabelProp === undefined ? true : floatingLabelProp;
const floating = hasLabel && !multiline && useFloatingLabel;
const stackedSingleLine = hasLabel && !multiline && !useFloatingLabel;
const inputTextClass = size === 'm' ? 'text-body-xs-plain' : 'text-body-s-plain';
const stackedLabelClass = size === 'm' ? 'text-label-xs-plain' : 'text-label-s-plain';
---

<div
  class={rootClass}
  data-variant={variant}
  data-label={hasLabel ? 'yes' : 'no'}
  data-tone={tone}
  data-disabled={disabled ? '' : undefined}
  data-multiline={multiline ? '' : undefined}
  data-floating={floating ? 'yes' : stackedSingleLine ? 'no' : undefined}
  data-size={size}
>
  <div class="ui-field__control">
    <div class="ui-field__slot-start">
      <slot name="slot-start" />
    </div>
    <label
      class:list={[
        'ui-field__focus-area',
        multiline && hasLabel && 'ui-field__focus-area--multiline-grid',
        stackedSingleLine && 'ui-field__focus-area--stacked-single',
      ]}
      for={id}
    >
      <span class="ui-field__icon-start">
        <slot name="icon-start" />
      </span>
      {
        floating ? (
          <span class="ui-field__body ui-field__body--float">
            <span class="ui-field__float-stack">
              <input
                class:list={['ui-field__input', inputTextClass]}
                type={type}
                id={id}
                name={name}
                placeholder={floatingPlaceholder}
                value={value}
                disabled={disabled}
                aria-invalid={tone === 'error' ? true : undefined}
                aria-describedby={hasHelper ? helperId : undefined}
                {...mobileInputAttrs}
              />
              <span class="ui-field__label">
                {label ? label : <slot name="label" />}
              </span>
            </span>
          </span>
        ) : stackedSingleLine ? (
          <>
            <span class:list={['ui-field__label', 'ui-field__label--stacked', stackedLabelClass]}>
              {label ? label : <slot name="label" />}
            </span>
            <span class="ui-field__body ui-field__body--stacked-single">
              <input
                class:list={['ui-field__input', inputTextClass]}
                type={type}
                id={id}
                name={name}
                placeholder={placeholder}
                value={value}
                disabled={disabled}
                aria-invalid={tone === 'error' ? true : undefined}
                aria-describedby={hasHelper ? helperId : undefined}
                {...mobileInputAttrs}
              />
            </span>
          </>
        ) : hasLabel && multiline ? (
          <>
            <span class:list={['ui-field__label', 'ui-field__label--stacked', stackedLabelClass]}>
              {label ? label : <slot name="label" />}
            </span>
            <textarea
              class:list={['ui-field__textarea', 'ui-field__input', inputTextClass]}
              id={id}
              name={name}
              rows={rows}
              placeholder={placeholder}
              disabled={disabled}
              aria-invalid={tone === 'error' ? true : undefined}
              aria-describedby={hasHelper ? helperId : undefined}
              {...mobileInputAttrs}
            >{value ?? ''}</textarea>
          </>
        ) : (
          <span class="ui-field__body">
            {multiline ? (
              <textarea
                class:list={['ui-field__textarea', 'ui-field__input', inputTextClass]}
                id={id}
                name={name}
                rows={rows}
                placeholder={placeholder}
                disabled={disabled}
                aria-invalid={tone === 'error' ? true : undefined}
                aria-describedby={hasHelper ? helperId : undefined}
                aria-label={ariaLabel}
                {...mobileInputAttrs}
              >{value ?? ''}</textarea>
            ) : (
              <input
                class:list={['ui-field__input', inputTextClass]}
                type={type}
                id={id}
                name={name}
                placeholder={placeholder}
                value={value}
                disabled={disabled}
                aria-invalid={tone === 'error' ? true : undefined}
                aria-describedby={hasHelper ? helperId : undefined}
                aria-label={ariaLabel}
                {...mobileInputAttrs}
              />
            )}
          </span>
        )
      }
      <span class="ui-field__icon-end">
        <slot name="icon-end" />
      </span>
    </label>
    <div class="ui-field__slot-end">
      <slot name="slot-end" />
    </div>
  </div>
  {
    hasHelper && (
      <div class="ui-field__helper text-body-xs-plain" id={helperId}>
        <span class="ui-field__description-icon">
          <slot name="description-icon" />
        </span>
        <span class="ui-field__description-text">
          {description ? description : <slot name="description" />}
        </span>
      </div>
    )
  }
</div>
