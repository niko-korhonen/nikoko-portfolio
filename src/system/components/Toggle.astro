---
interface Props {
  name?: string;
  value?: string;
  checked?: boolean;
  disabled?: boolean;
}

const { name, value, checked = false, disabled = false } = Astro.props;
---

<label class="ui-toggle">
  <input
    type="checkbox"
    role="switch"
    class="ui-toggle__input"
    name={name}
    value={value}
    checked={checked}
    disabled={disabled}
  />
  <span class="ui-toggle__track" aria-hidden="true">
    <span class="ui-toggle__thumb"></span>
  </span>
</label>
