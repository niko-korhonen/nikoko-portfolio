---
import { randomUUID } from 'node:crypto';

export type ModalDialogLayout = 'centered' | 'footer';

/**
 * Slots:
 * - **toolbar** — Top bar (e.g. `ButtonIcon` close/back). Omit with `toolbar={false}`.
 * - **hero** — Optional **single** hero icon at **L** size, centered above the title. Omit the slot, leave it empty, or set `showHero={false}` when no hero.
 * - **title** — Main heading (Label L). Plain text or inline markup.
 * - **description** — Supporting copy (Body S).
 * - **center** — `layout="centered"` only: custom region below the description (e.g. primary action).
 * - **footer** — `layout="footer"` only: stacked full-width actions.
 */
interface Props {
  /**
   * centered — single custom region below copy with wide horizontal padding and bottom inset.
   * footer — full-width action stack in a bottom bar.
   */
  layout?: ModalDialogLayout;
  /**
   * When true, Escape and backdrop click close the dialog.
   * When false, only explicit close targets (e.g. data-modal-dialog-close) close it.
   * @default true
   */
  dismissible?: boolean;
  /** @default true */
  toolbar?: boolean;
  /**
   * Toolbar icon alignment (ButtonIcon M sits with 16px inset inside the bar).
   * @default 'end'
   */
  toolbarAlign?: 'start' | 'end';
  /** Stable id for `document.getElementById` / `showModal()`. */
  id?: string;
  class?: string;
  /** Dialog accessible name when the title slot is empty. */
  ariaLabel?: string;
  /**
   * When false, the hero region is not rendered (no hero slot). Use when you want no hero without an empty slot.
   * @default true
   */
  showHero?: boolean;
}

const {
  layout = 'centered',
  dismissible = true,
  toolbar = true,
  toolbarAlign = 'end',
  id: idProp,
  class: className = '',
  ariaLabel,
  showHero = true,
} = Astro.props;

const dialogId = idProp ?? `modal-dialog-${randomUUID()}`;
const titleId = `${dialogId}-title`;
const descId = `${dialogId}-description`;

const rootClass = ['ui-modal-dialog', className].filter(Boolean).join(' ');

const a11y =
  ariaLabel != null && ariaLabel !== ''
    ? ({ 'aria-label': ariaLabel, 'aria-describedby': descId } as const)
    : ({ 'aria-labelledby': titleId, 'aria-describedby': descId } as const);
---

<dialog
  id={dialogId}
  class={rootClass}
  data-modal-dialog
  data-dismissible={dismissible ? 'true' : 'false'}
  data-layout={layout}
  aria-modal="true"
  {...a11y}
>
  <div class="ui-modal-dialog__panel">
    {
      toolbar ? (
        <div class="ui-modal-dialog__toolbar" data-toolbar-align={toolbarAlign}>
          <div class="ui-modal-dialog__toolbar-inner">
            <slot name="toolbar" />
          </div>
        </div>
      ) : null
    }

    <div class="ui-modal-dialog__body">
      {
        showHero ? (
          <div class="ui-modal-dialog__hero">
            <slot name="hero" />
          </div>
        ) : null
      }

      <h2 id={titleId} class="ui-modal-dialog__title text-label-l-plain">
        <slot name="title" />
      </h2>

      <p id={descId} class="ui-modal-dialog__description text-body-s-plain">
        <slot name="description" />
      </p>

      {
        layout === 'centered' ? (
          <div class="ui-modal-dialog__center">
            <slot name="center" />
          </div>
        ) : null
      }
    </div>

    {layout === 'footer' ? (
      <div class="ui-modal-dialog__footer">
        <slot name="footer" />
      </div>
    ) : null}
  </div>
</dialog>

<script>
  import { initModalDialogs } from './modal-dialog.ts';

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initModalDialogs, { once: true });
  } else {
    initModalDialogs();
  }
</script>
