---
import Icon from '../icons/Icon.astro';
import type { IconStyle } from '../icons/Icon.astro';

export type SegmentSemantic = 'radiogroup' | 'tablist';
export type SegmentSize = 'l' | 'm' | 's';

export type SegmentItem = {
  value: string;
  label?: string;
  icon?: string;
  iconStyle?: IconStyle;
  /** If omitted, inferred from label / icon presence */
  content?: 'icon' | 'label' | 'both';
  /** tablist: id of the controlled tabpanel */
  ariaControls?: string;
  /** Accessible name (required for meaningful icon-only items) */
  ariaLabel?: string;
  disabled?: boolean;
};

interface Props {
  /** radiogroup = single choice / form-like; tablist = tab strip (pair with tabpanels by id) */
  semantic?: SegmentSemantic;
  size?: SegmentSize;
  /** When set, a hidden input is kept in sync for forms */
  name?: string;
  /** Initial selection (uncontrolled SSR) */
  defaultValue?: string;
  /** Accessible name for the group (use this or ariaLabelledby) */
  ariaLabel?: string;
  ariaLabelledby?: string;
  items: SegmentItem[];
  disabled?: boolean;
  class?: string;
}

function inferContent(item: SegmentItem): 'icon' | 'label' | 'both' {
  if (item.content) return item.content;
  if (item.icon && item.label) return 'both';
  if (item.icon && !item.label) return 'icon';
  return 'label';
}

function iconSizeForSegment(size: SegmentSize): 'm' | 's' {
  return size === 'l' ? 'm' : 's';
}

function sanitizeIdPart(s: string) {
  return s.replace(/[^a-zA-Z0-9_-]/g, '-');
}

function accessibleName(item: SegmentItem, mode: 'icon' | 'label' | 'both'): string | undefined {
  if (item.ariaLabel) return item.ariaLabel;
  if (mode === 'icon') return item.label ?? item.value;
  return undefined;
}

const {
  semantic = 'radiogroup',
  size = 'm',
  name,
  defaultValue,
  ariaLabel,
  ariaLabelledby,
  items,
  disabled = false,
  class: className = '',
} = Astro.props;

const typoClass =
  size === 'l' ? 'text-label-m-plain' : size === 's' ? 'text-label-xs-plain' : 'text-label-s-plain';

const defaultOk =
  defaultValue !== undefined &&
  items.some((i) => i.value === defaultValue && !disabled && !i.disabled);

const initial = defaultOk
  ? defaultValue!
  : items.find((i) => !disabled && !i.disabled)?.value ?? items[0]?.value;

const segmentUid = crypto.randomUUID();
---

<div
  class:list={['ui-segment', className]}
  data-ui-segment
  data-ui-semantic={semantic}
  data-ui-segment-id={segmentUid}
>
  {name ? <input type="hidden" class="ui-segment__field" name={name} value={initial ?? ''} /> : null}
  <div
    class="ui-segment__track"
    role={semantic === 'tablist' ? 'tablist' : 'radiogroup'}
    aria-label={ariaLabelledby ? undefined : ariaLabel}
    aria-labelledby={ariaLabelledby}
  >
    <span class="ui-segment__indicator" aria-hidden="true" />
    {
      items.map((item) => {
        const mode = inferContent(item);
        const isSelected = item.value === initial;
        const itemDisabled = disabled || item.disabled;
        const iconStyle = item.iconStyle ?? 'outline';
        const iconSize = iconSizeForSegment(size);
        const id = `segment-${segmentUid}-${sanitizeIdPart(item.value)}`;
        const a11yName = accessibleName(item, mode);

        return (
          <button
            type="button"
            class:list={['ui-segment__cell', 'ui-focus-ring', typoClass]}
            data-size={size}
            data-value={item.value}
            data-selected={isSelected ? 'true' : 'false'}
            tabindex={isSelected ? 0 : -1}
            disabled={itemDisabled}
            id={id}
            aria-label={a11yName}
            role={semantic === 'tablist' ? 'tab' : 'radio'}
            {...(semantic === 'tablist'
              ? {
                  'aria-selected': isSelected ? 'true' : 'false',
                  ...(item.ariaControls ? { 'aria-controls': item.ariaControls } : {}),
                }
              : {
                  'aria-checked': isSelected ? 'true' : 'false',
                })}
          >
            {mode !== 'label' && item.icon ? (
              <span class="ui-btn__icon">
                <Icon name={item.icon} style={iconStyle} size={iconSize} />
              </span>
            ) : null}
            {mode !== 'icon' && item.label ? <span class="ui-btn__label">{item.label}</span> : null}
          </button>
        );
      })
    }
  </div>
</div>

<script>
  import './segment-control.ts';
</script>
