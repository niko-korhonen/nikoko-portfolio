---
export type RadioSize = 'l' | 'm' | 's';

interface Props {
  name: string;
  value: string;
  size?: RadioSize;
  checked?: boolean;
  disabled?: boolean;
}

const {
  name,
  value,
  size = 'm',
  checked = false,
  disabled = false,
} = Astro.props;
---

<label class="ui-radio" data-size={size}>
  <input
    type="radio"
    class="ui-radio__input"
    name={name}
    value={value}
    checked={checked}
    disabled={disabled}
  />
  <span class="ui-radio__control" aria-hidden="true"></span>
  <span class="ui-radio__label text-body-s-plain">
    <slot />
  </span>
</label>
