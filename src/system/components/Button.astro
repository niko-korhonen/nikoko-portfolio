---
export type ButtonVariant = 'primary' | 'secondary' | 'ghost' | 'accent';
export type ButtonSize = 'l' | 'm' | 's';

interface Props {
  variant?: ButtonVariant;
  size?: ButtonSize;
  disabled?: boolean;
  type?: 'button' | 'submit' | 'reset';
  class?: string;
  /** When set, renders an anchor with the same button styles (navigation). */
  href?: string;
}

const {
  variant = 'primary',
  size = 'm',
  disabled = false,
  type = 'button',
  class: className = '',
  href,
} = Astro.props;

const typoClass =
  size === 'l' ? 'text-label-m-plain' : size === 's' ? 'text-label-xs-plain' : 'text-label-s-plain';

const btnClass = ['ui-btn', 'ui-focus-ring', typoClass, className].filter(Boolean).join(' ');
---

{
  href ? (
    <a class={btnClass} href={href} data-variant={variant} data-size={size}>
      <span class="ui-btn__icon">
        <slot name="icon-start" />
      </span>
      <span class="ui-btn__label">
        <slot />
      </span>
      <span class="ui-btn__icon">
        <slot name="icon-end" />
      </span>
    </a>
  ) : (
    <button class={btnClass} type={type} disabled={disabled} data-variant={variant} data-size={size}>
      <span class="ui-btn__icon">
        <slot name="icon-start" />
      </span>
      <span class="ui-btn__label">
        <slot />
      </span>
      <span class="ui-btn__icon">
        <slot name="icon-end" />
      </span>
    </button>
  )
}
