---
export type ButtonVariant = 'primary' | 'secondary' | 'ghost' | 'accent';
export type ButtonSize = 'l' | 'm' | 's';

interface Props {
  variant?: ButtonVariant;
  size?: ButtonSize;
  disabled?: boolean;
  type?: 'button' | 'submit' | 'reset';
  class?: string;
  /** When set, renders an anchor with the same button styles (navigation). */
  href?: string;
  /** When used inside ModalDialog (button only), closes the dialog on click. */
  dialogClose?: boolean;
  /** Showcase text-field Clear: target input id. */
  'data-ds-clear'?: string;
}

const {
  variant = 'primary',
  size = 'm',
  disabled = false,
  type = 'button',
  class: className = '',
  href,
  dialogClose = false,
  'data-ds-clear': dataDsClear,
} = Astro.props;

const typoClass =
  size === 'l' ? 'text-label-m-plain' : size === 's' ? 'text-label-xs-plain' : 'text-label-s-plain';

const btnClass = ['ui-btn', 'ui-focus-ring', typoClass, className].filter(Boolean).join(' ');
---

{
  href ? (
    <a
      class={btnClass}
      href={href}
      data-variant={variant}
      data-size={size}
      {...(dataDsClear !== undefined ? { 'data-ds-clear': dataDsClear } : {})}
    >
      <span class="ui-btn__icon">
        <slot name="icon-start" />
      </span>
      <span class="ui-btn__label">
        <slot />
      </span>
      <span class="ui-btn__icon">
        <slot name="icon-end" />
      </span>
    </a>
  ) : (
    <button
      class={btnClass}
      type={type}
      disabled={disabled}
      data-variant={variant}
      data-size={size}
      {...dialogClose ? ({ 'data-modal-dialog-close': '' } as const) : {}}
      {...(dataDsClear !== undefined ? { 'data-ds-clear': dataDsClear } : {})}
    >
      <span class="ui-btn__icon">
        <slot name="icon-start" />
      </span>
      <span class="ui-btn__label">
        <slot />
      </span>
      <span class="ui-btn__icon">
        <slot name="icon-end" />
      </span>
    </button>
  )
}
