---
import type { PopoverAlign, PopoverPosition } from '../placement';

interface Props {
  /**
   * Id for the tooltip surface (`role="tooltip"`). Use the same value for
   * `aria-describedby` on the trigger. Auto-generated when omitted.
   */
  id?: string;
  /**
   * Which side of the trigger the tooltip appears on.
   * @default 'top'
   */
  position?: PopoverPosition;
  /**
   * Cross-axis alignment relative to the trigger.
   * @default 'center'
   */
  align?: PopoverAlign;
}

const {
  id: idProp,
  position = 'top',
  align = 'center',
} = Astro.props;

const tooltipId = idProp ?? `tt-${Math.random().toString(36).slice(2, 11)}`;
---

<div class="ui-tooltip">
  <span class="ui-tooltip__anchor">
    <slot name="trigger" />
  </span>
  <span
    id={tooltipId}
    class="ui-tooltip__surface text-body-xs-plain"
    role="tooltip"
    data-popover-position={position}
    data-popover-align={align}
  >
    <slot name="content" />
  </span>
</div>
