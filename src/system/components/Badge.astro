---
export type BadgeVariant = 'primary' | 'inverse' | 'accent';

interface Props {
  variant?: BadgeVariant;
  class?: string;
}

const { variant = 'primary', class: className = '' } = Astro.props;
---

<span class={['ui-badge', 'text-label-xxs-plain', className].filter(Boolean).join(' ')} data-variant={variant}>
  <slot />
</span>
