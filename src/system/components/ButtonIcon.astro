---
export type ButtonIconVariant = 'primary' | 'secondary' | 'ghost' | 'accent';
export type ButtonIconSize = 'l' | 'm' | 's';

interface Props {
  variant?: ButtonIconVariant;
  size?: ButtonIconSize;
  disabled?: boolean;
  type?: 'button' | 'submit' | 'reset';
  /** Required for icon-only control accessibility */
  label: string;
  class?: string;
  /** When set, renders an anchor with the same icon button styles. */
  href?: string;
  /** When used inside ModalDialog, closes the dialog on click. */
  dialogClose?: boolean;
}

const {
  variant = 'primary',
  size = 'm',
  disabled = false,
  type = 'button',
  label,
  class: className = '',
  href,
  dialogClose = false,
} = Astro.props;

const iconClass = ['ui-btn-icon', 'ui-focus-ring', className].filter(Boolean).join(' ');
---

{
  href ? (
    <a
      class={iconClass}
      href={href}
      data-variant={variant}
      data-size={size}
      aria-label={label}
    >
      <slot />
    </a>
  ) : (
    <button
      class={iconClass}
      type={type}
      disabled={disabled}
      data-variant={variant}
      data-size={size}
      aria-label={label}
      {...dialogClose ? ({ 'data-modal-dialog-close': '' } as const) : {}}
    >
      <slot />
    </button>
  )
}
