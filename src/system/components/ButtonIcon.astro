---
export type ButtonIconVariant = 'primary' | 'secondary' | 'ghost' | 'accent';
export type ButtonIconSize = 'l' | 'm' | 's';

interface Props {
  variant?: ButtonIconVariant;
  size?: ButtonIconSize;
  disabled?: boolean;
  type?: 'button' | 'submit' | 'reset';
  /** Required for icon-only control accessibility */
  label: string;
  class?: string;
  /** When used inside ModalDialog, closes the dialog on click. */
  dialogClose?: boolean;
}

const {
  variant = 'primary',
  size = 'm',
  disabled = false,
  type = 'button',
  label,
  class: className = '',
  dialogClose = false,
} = Astro.props;
---

<button
  class={['ui-btn-icon', 'ui-focus-ring', className].filter(Boolean).join(' ')}
  type={type}
  disabled={disabled}
  data-variant={variant}
  data-size={size}
  aria-label={label}
  {...dialogClose ? ({ 'data-modal-dialog-close': '' } as const) : {}}
>
  <slot />
</button>
