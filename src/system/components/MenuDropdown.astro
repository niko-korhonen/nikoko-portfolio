---
import { randomUUID } from 'node:crypto';
import type { PopoverAlign, PopoverPosition } from '../placement';
import ElevatedPanel from './ElevatedPanel.astro';
import MenuList from './MenuList.astro';

interface Props {
  /**
   * Which side of the trigger the menu opens toward.
   * @default 'bottom'
   */
  position?: PopoverPosition;
  /**
   * Cross-axis alignment (e.g. for bottom/top: start = inline-start with trigger).
   * @default 'start'
   */
  align?: PopoverAlign;
}

const { position = 'bottom', align = 'start' } = Astro.props;

const panelId = `menu-panel-${randomUUID()}`;
---

<div class="ui-menu-dropdown" data-menu-dropdown>
  <div class="ui-menu-dropdown__trigger-wrap">
    <slot name="trigger" />
  </div>
  <div
    id={panelId}
    class="ui-menu-dropdown__panel"
    data-menu-dropdown-panel
    data-popover-position={position}
    data-popover-align={align}
    hidden
    role="menu"
    aria-label="Menu"
  >
    <ElevatedPanel>
      <MenuList>
        <slot />
      </MenuList>
    </ElevatedPanel>
  </div>
</div>

<script>
  import { initAllMenuDropdowns } from './menu-dropdown-placement';

  function boot() {
    initAllMenuDropdowns();
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', boot);
  } else {
    boot();
  }
</script>
