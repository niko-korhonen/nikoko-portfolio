---
interface Props {
  class?: string;
  /** For anchor links / aria */
  labelledBy?: string;
}

const { class: className = '', labelledBy } = Astro.props;
---

<div
  class:list={['ds-showcase-preview', className]}
  role="region"
  aria-label="Component preview"
  {...labelledBy ? ({ 'aria-labelledby': labelledBy } as const) : {}}
>
  <div class="ds-showcase-preview__inner">
    <slot />
  </div>
</div>
