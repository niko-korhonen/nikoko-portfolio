---
/**
 * Same chrome as ShowcaseControlsTable: bordered table for documentation rows
 * (prop name + description), not interactive controls.
 */
interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;
---

<div class:list={['ds-showcase-controls', 'ds-showcase-props-doc', className]}>
  <table class="ds-showcase-table ds-showcase-table--props-doc">
    <thead>
      <tr>
        <th class="text-label-xs-plain ds-showcase-table__th" scope="col">Prop</th>
        <th class="text-label-xs-plain ds-showcase-table__th" scope="col">Description</th>
      </tr>
    </thead>
    <tbody>
      <slot />
    </tbody>
  </table>
</div>
