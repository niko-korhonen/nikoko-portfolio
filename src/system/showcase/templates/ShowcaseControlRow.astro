---
interface Props {
  label: string;
  class?: string;
  hidden?: boolean;
}

const { label, class: className = '', hidden } = Astro.props;
---

<tr class:list={['ds-showcase-table__row', className]} hidden={hidden ?? undefined}>
  <td class="text-body-xs-plain ds-showcase-table__label">{label}</td>
  <td class="ds-showcase-table__control">
    <slot />
  </td>
</tr>
