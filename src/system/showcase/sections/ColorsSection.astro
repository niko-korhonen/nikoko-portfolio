---
import ComponentShowcasePage from '../templates/ComponentShowcasePage.astro';
import { colorGroups } from '../data';
---

<ComponentShowcasePage
  title="Colors"
  headingId="colors-heading"
  description="Semantic color tokens for content, surfaces, outlines, components, and overlays. Prefer these variables over raw values so themes and contrast stay consistent."
>
  <section class="ds-showcase-palette">
    <h2 class="text-label-s-plain ds-showcase-palette-title">Full palette reference</h2>
    {
      colorGroups.map((group) => (
        <div class="subsection" style="margin-top: var(--space-16)">
          <h3 class="text-label-xs-plain" style="margin-bottom: var(--space-8); color: var(--color-content-secondary);">
            {group.title}
          </h3>
          <ul class="swatch-grid">
            {group.tokens.map((token) => (
              <li class="swatch">
                {token.startsWith('outline-') ? (
                  <div
                    class="swatch__outline"
                    style={`border-color: var(--color-${token}); background: var(--color-surface-base);`}
                  />
                ) : token.startsWith('overlay-') ? (
                  <div class="swatch__alpha-bg">
                    <div class="swatch__fill" style={`background: var(--color-${token});`} />
                  </div>
                ) : token.startsWith('component-') &&
                  (token.includes('active') || token.includes('hover') || token.includes('pressed')) ? (
                  <div class="swatch__alpha-bg">
                    <div class="swatch__fill" style={`background: var(--color-${token});`} />
                  </div>
                ) : (
                  <div class="swatch__fill" style={`background: var(--color-${token});`} />
                )}
                <span class="text-body-xs-plain swatch__name">{`--color-${token}`}</span>
              </li>
            ))}
          </ul>
        </div>
      ))
    }
    <div class="subsection" style="margin-top: var(--space-16)">
      <h3 class="text-label-xs-plain" style="margin-bottom: var(--space-8); color: var(--color-content-secondary);">
        Other
      </h3>
      <p class="text-body-xs-plain">
        <code class="code-inline">--opacity-component-disabled</code>
        <span class="muted"> → </span>
        <span class="text-body-xs-emphasized">{`var(--opacity-component-disabled)`}</span>
        <span class="opacity-demo" style={`opacity: var(--opacity-component-disabled);`} aria-hidden="true">
          Sample
        </span>
      </p>
    </div>
  </section>
</ComponentShowcasePage>
