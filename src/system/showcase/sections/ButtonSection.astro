---
import Button from '../../components/Button.astro';
import ButtonDropdown from '../../components/ButtonDropdown.astro';
import MenuDropdown from '../../components/MenuDropdown.astro';
import MenuItemAction from '../../components/MenuItemAction.astro';
import Toggle from '../../components/Toggle.astro';
import ComponentShowcasePage from '../templates/ComponentShowcasePage.astro';
import ShowcaseAccentContainerRow from '../templates/ShowcaseAccentContainerRow.astro';
import ShowcaseTextFieldControl from '../templates/ShowcaseTextFieldControl.astro';
import ShowcasePreviewCard from '../templates/ShowcasePreviewCard.astro';
import ShowcaseControlsTable from '../templates/ShowcaseControlsTable.astro';
import ShowcaseControlRow from '../templates/ShowcaseControlRow.astro';
import ShowcaseCopyPrompt from '../templates/ShowcaseCopyPrompt.astro';
import ShowcaseIconMenuItems from '../templates/ShowcaseIconMenuItems.astro';
import { getAllIconVariantMenuEntries, loadAllIconVariantInlineMap } from '../showcase-icons';
import { accentTokenCssVar, accentTokenMenuLabel, btnMatrixVariants, btnMatrixSizes } from '../data';

const iconVariantMenu = getAllIconVariantMenuEntries();
const iconHtmlMap: Record<string, string> = { none: '', ...loadAllIconVariantInlineMap() };
const variantLabels = Object.fromEntries(btnMatrixVariants.map((v) => [v, v.charAt(0).toUpperCase() + v.slice(1)]));
---

<ComponentShowcasePage
  title="Button"
  headingId="button-heading"
  description="Primary actions, navigation links, and dialog actions. Variants set visual weight; size maps to label typography. The accent variant uses the system accent container token. Optional icon-start / icon-end slots align with the label."
>
  <ShowcasePreviewCard>
    <div class="ds-showcase-demo-root" data-ds-demo="button">
      <button
        id="ds-btn-preview"
        class="ui-btn ui-focus-ring text-label-s-plain"
        type="button"
        data-variant="primary"
        data-size="m"
      >
        <span class="ui-btn__icon" data-ds-icon-start></span>
        <span class="ui-btn__label">Label</span>
        <span class="ui-btn__icon" aria-hidden="true"></span>
      </button>
    </div>
  </ShowcasePreviewCard>

  <ShowcaseControlsTable>
    <ShowcaseControlRow label="Variant">
      <MenuDropdown>
        <ButtonDropdown slot="trigger" variant="secondary" size="s" type="button">
          <span data-ds-dd="variant-label">{variantLabels.primary}</span>
        </ButtonDropdown>
        {
          btnMatrixVariants.map((v) => (
            <MenuItemAction type="button" data-ds-pick="variant" data-value={v}>
              {variantLabels[v]}
            </MenuItemAction>
          ))
        }
      </MenuDropdown>
    </ShowcaseControlRow>
    <ShowcaseControlRow label="Size">
      <MenuDropdown>
        <ButtonDropdown slot="trigger" variant="secondary" size="s" type="button">
          <span data-ds-dd="size-label">M</span>
        </ButtonDropdown>
        {
          btnMatrixSizes.map((s) => (
            <MenuItemAction type="button" data-ds-pick="size" data-value={s}>
              {s.toUpperCase()}
            </MenuItemAction>
          ))
        }
      </MenuDropdown>
    </ShowcaseControlRow>
    <ShowcaseControlRow label="Label">
      <ShowcaseTextFieldControl id="ds-btn-label-tf" ariaLabel="Button label text" placeholder="Label" />
    </ShowcaseControlRow>
    <ShowcaseControlRow label="Icon start">
      <MenuDropdown>
        <ButtonDropdown slot="trigger" variant="secondary" size="s" type="button">
          <span data-ds-dd="icon-label">None</span>
        </ButtonDropdown>
        <ShowcaseIconMenuItems dataPick="icon" entries={iconVariantMenu} />
      </MenuDropdown>
    </ShowcaseControlRow>
    <ShowcaseAccentContainerRow />
    <ShowcaseControlRow label="Disabled">
      <div class="ds-showcase-toggle-wrap" data-ds-toggle="disabled">
        <Toggle name="ds-btn-disabled" />
      </div>
    </ShowcaseControlRow>
  </ShowcaseControlsTable>

  <ShowcaseCopyPrompt componentLabel="Button" />
</ComponentShowcasePage>

<script is:inline define:vars={{ iconHtmlMap }}>
  globalThis['__dsShowcaseBtnIconHtmlMap'] = iconHtmlMap;
</script>
<script>
  import { buildCopyPrompt } from '../copy-prompt';
  import { accentContainerTokens, accentTokenCssVar, accentTokenMenuLabel } from '../data';

  type AccentTok = (typeof accentContainerTokens)[number];
  import { bindFieldClear, getShowcasePage, takeInjectedIconHtmlMap } from '../showcase-ui';

  function typoForSize(size: string) {
    if (size === 'l') return 'text-label-m-plain';
    if (size === 's') return 'text-label-xs-plain';
    return 'text-label-s-plain';
  }

  function iconSizeForBtn(size: string) {
    return size === 'l' ? 'm' : 's';
  }

  function init() {
    const page = getShowcasePage();
    const root = document.querySelector('[data-ds-demo="button"]');
    const btn = document.getElementById('ds-btn-preview');
    const labelInput = document.getElementById('ds-btn-label-tf') as HTMLInputElement | null;
    if (!page || !root || !btn || !labelInput) return;

    bindFieldClear(page);

    const iconStart = btn.querySelector('[data-ds-icon-start]') as HTMLElement;
    const labelEl = btn.querySelector('.ui-btn__label');
    const variantLabel = page.querySelector('[data-ds-dd="variant-label"]');
    const sizeLabel = page.querySelector('[data-ds-dd="size-label"]');
    const iconLabel = page.querySelector('[data-ds-dd="icon-label"]');
    const disabledCb = page.querySelector<HTMLInputElement>(
      '[data-ds-toggle="disabled"] input[role="switch"]',
    );
    const accentRow = page.querySelector<HTMLTableRowElement>('tr.js-ds-accent-token-row');
    const accentLabel = page.querySelector('[data-ds-dd="accent-token-label"]');

    const map: Record<string, string> = { none: '', ...takeInjectedIconHtmlMap('__dsShowcaseBtnIconHtmlMap') };

    let variant = 'primary';
    let size = 'm';
    let iconKey = 'none';
    let accentToken: AccentTok = 'container-accent-blue';

    function applyIcon() {
      const html = map[iconKey] || '';
      if (!iconStart) return;
      if (!html) {
        iconStart.innerHTML = '';
        return;
      }
      const isz = iconSizeForBtn(size);
      const istyle = iconKey.endsWith('-fill') ? 'fill' : 'outline';
      iconStart.innerHTML = `<span class="ui-icon" data-size="${isz}" data-style="${istyle}">${html}</span>`;
    }

    function apply() {
      btn.setAttribute('data-variant', variant);
      btn.setAttribute('data-size', size);
      btn.disabled = Boolean(disabledCb?.checked);
      btn.className = ['ui-btn', 'ui-focus-ring', typoForSize(size)].join(' ');
      if (labelEl) labelEl.textContent = labelInput.value || 'Label';
      if (variantLabel) variantLabel.textContent = variant.charAt(0).toUpperCase() + variant.slice(1);
      if (sizeLabel) sizeLabel.textContent = size.toUpperCase();
      if (iconLabel) {
        iconLabel.textContent = iconKey === 'none' ? 'None' : `icon-${iconKey}`;
      }
      if (accentRow) accentRow.hidden = variant !== 'accent';
      if (variant === 'accent') {
        btn.style.setProperty('background', accentTokenCssVar(accentToken));
      } else {
        btn.style.removeProperty('background');
      }
      if (accentLabel) accentLabel.textContent = accentTokenMenuLabel(accentToken);
      applyIcon();
    }

    page.querySelectorAll('[data-ds-pick="variant"]').forEach((el) => {
      el.addEventListener('click', () => {
        const v = (el as HTMLElement).dataset.value;
        if (v) {
          variant = v;
          apply();
        }
      });
    });
    page.querySelectorAll('[data-ds-pick="size"]').forEach((el) => {
      el.addEventListener('click', () => {
        const v = (el as HTMLElement).dataset.value;
        if (v) {
          size = v;
          apply();
        }
      });
    });
    page.querySelectorAll('[data-ds-pick="icon"]').forEach((el) => {
      el.addEventListener('click', () => {
        const v = (el as HTMLElement).dataset.value;
        if (v) {
          iconKey = v;
          apply();
        }
      });
    });
    page.querySelectorAll('[data-ds-pick="accent-token"]').forEach((el) => {
      el.addEventListener('click', () => {
        const v = (el as HTMLElement).dataset.value;
        if (v) {
          accentToken = v as AccentTok;
          apply();
        }
      });
    });

    labelInput.addEventListener('input', apply);
    disabledCb?.addEventListener('change', apply);
    apply();

    page.querySelector('.js-ds-showcase-copy')?.addEventListener('click', async () => {
      const text = buildCopyPrompt({
        component: 'Button',
        props: {
          variant,
          size,
          label: labelInput.value || 'Label',
          disabled: Boolean(disabledCb?.checked),
          iconStart: iconKey === 'none' ? 'none' : `icon-${iconKey}.svg`,
          ...(variant === 'accent' ? { accentContainer: accentToken } : {}),
        },
      });
      try {
        await navigator.clipboard.writeText(text);
      } catch {
        /* ignore */
      }
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
</script>
