---
import Button from '../../components/Button.astro';
import ButtonDropdown from '../../components/ButtonDropdown.astro';
import MenuDropdown from '../../components/MenuDropdown.astro';
import MenuItemAction from '../../components/MenuItemAction.astro';
import ComponentShowcasePage from '../templates/ComponentShowcasePage.astro';
import ShowcaseAccentContainerRow from '../templates/ShowcaseAccentContainerRow.astro';
import ShowcaseTextFieldControl from '../templates/ShowcaseTextFieldControl.astro';
import ShowcasePreviewCard from '../templates/ShowcasePreviewCard.astro';
import ShowcaseControlsTable from '../templates/ShowcaseControlsTable.astro';
import ShowcaseControlRow from '../templates/ShowcaseControlRow.astro';
import ShowcaseCopyPrompt from '../templates/ShowcaseCopyPrompt.astro';
import ShowcaseIconMenuItems from '../templates/ShowcaseIconMenuItems.astro';
import { getAllIconVariantMenuEntries, loadAllIconVariantInlineMap } from '../showcase-icons';
import { accentTokenCssVar, accentTokenMenuLabel, btnMatrixVariants, btnMatrixSizes } from '../data';

const iconVariantMenu = getAllIconVariantMenuEntries();
const iconHtmlMap: Record<string, string> = { none: '', ...loadAllIconVariantInlineMap() };
const variantLabels = Object.fromEntries(btnMatrixVariants.map((v) => [v, v.charAt(0).toUpperCase() + v.slice(1)]));
---

<ComponentShowcasePage
  title="ScorePillCounter"
  headingId="score-pill-counter-heading"
  description="Non-interactive pill that matches Button sizing, variants, and optional icon-start. Use it to surface numeric scores or tallies; the value animates with a vertical slot transition. Optional leading or trailing labels stay static (for example “0 of 211” with only the number animating). Wire the count from your app state and call setScorePillValue when it changes."
>
  <ShowcasePreviewCard>
    <div class="ds-showcase-demo-root" data-ds-demo="score-pill-counter">
      <div class="ds-score-pill-preview-row">
        <span
          id="ds-score-pill-preview"
          class="ui-btn ui-score-pill text-label-s-plain"
          data-variant="primary"
          data-size="m"
          data-ui-score-pill
          data-value="0"
          role="status"
          aria-live="polite"
          aria-atomic="true"
          aria-label="0"
        >
          <span class="ui-btn__icon" data-ds-icon-start></span>
          <span class="ui-btn__label ui-score-pill__label">
            <span class="ui-score-pill__leading" data-ds-leading></span>
            <span class="ui-score-pill__value">
              <span class="ui-score-pill__value-window">
                <span class="ui-score-pill__value-track">
                  <span class="ui-score-pill__digit">0</span>
                </span>
              </span>
            </span>
            <span class="ui-score-pill__trailing" data-ds-trailing></span>
          </span>
          <span class="ui-btn__icon" aria-hidden="true"></span>
        </span>
        <div class="ds-score-pill-stepper">
          <Button id="ds-score-pill-minus" variant="secondary" size="s" type="button">−1</Button>
          <Button id="ds-score-pill-plus" variant="secondary" size="s" type="button">+1</Button>
        </div>
      </div>
    </div>
  </ShowcasePreviewCard>

  <ShowcaseControlsTable>
    <ShowcaseControlRow label="Variant">
      <MenuDropdown>
        <ButtonDropdown slot="trigger" variant="secondary" size="s" type="button">
          <span data-ds-dd="variant-label">{variantLabels.primary}</span>
        </ButtonDropdown>
        {
          btnMatrixVariants.map((v) => (
            <MenuItemAction type="button" data-ds-pick="variant" data-value={v}>
              {variantLabels[v]}
            </MenuItemAction>
          ))
        }
      </MenuDropdown>
    </ShowcaseControlRow>
    <ShowcaseControlRow label="Size">
      <MenuDropdown>
        <ButtonDropdown slot="trigger" variant="secondary" size="s" type="button">
          <span data-ds-dd="size-label">M</span>
        </ButtonDropdown>
        {
          btnMatrixSizes.map((s) => (
            <MenuItemAction type="button" data-ds-pick="size" data-value={s}>
              {s.toUpperCase()}
            </MenuItemAction>
          ))
        }
      </MenuDropdown>
    </ShowcaseControlRow>
    <ShowcaseControlRow label="Value">
      <ShowcaseTextFieldControl id="ds-score-pill-value-tf" ariaLabel="Counter value" placeholder="0" />
    </ShowcaseControlRow>
    <ShowcaseControlRow label="Leading label">
      <ShowcaseTextFieldControl id="ds-score-pill-leading-tf" ariaLabel="Leading label (static)" placeholder="Empty" />
    </ShowcaseControlRow>
    <ShowcaseControlRow label="Trailing label">
      <ShowcaseTextFieldControl id="ds-score-pill-trailing-tf" ariaLabel="Trailing label (static)" placeholder="Empty" />
    </ShowcaseControlRow>
    <ShowcaseControlRow label="Icon start">
      <MenuDropdown>
        <ButtonDropdown slot="trigger" variant="secondary" size="s" type="button">
          <span data-ds-dd="icon-label">None</span>
        </ButtonDropdown>
        <ShowcaseIconMenuItems dataPick="icon" entries={iconVariantMenu} />
      </MenuDropdown>
    </ShowcaseControlRow>
    <ShowcaseAccentContainerRow />
  </ShowcaseControlsTable>

  <ShowcaseCopyPrompt componentLabel="ScorePillCounter" />
</ComponentShowcasePage>

<script is:inline define:vars={{ iconHtmlMap }}>
  globalThis['__dsShowcaseScorePillIconHtmlMap'] = iconHtmlMap;
</script>
<script>
  import { buildCopyPrompt } from '../copy-prompt';
  import { accentContainerTokens, accentTokenCssVar, accentTokenMenuLabel } from '../data';
  import { setScorePillValue } from '../../components/score-pill-counter';
  import { bindFieldClear, getShowcasePage, takeInjectedIconHtmlMap } from '../showcase-ui';

  type AccentTok = (typeof accentContainerTokens)[number];

  function typoForSize(size: string) {
    if (size === 'l') return 'text-label-m-plain';
    if (size === 's') return 'text-label-xs-plain';
    return 'text-label-s-plain';
  }

  function iconSizeForBtn(size: string) {
    return size === 'l' ? 'm' : 's';
  }

  function parseNonNegInt(raw: string): number {
    const n = Number.parseInt(raw.replace(/\D/g, ''), 10);
    if (!Number.isFinite(n) || n < 0) return 0;
    return n;
  }

  function init() {
    const root = document.querySelector('[data-ds-demo="score-pill-counter"]');
    const page = getShowcasePage(root);
    const pill = document.getElementById('ds-score-pill-preview');
    const valueInput = document.getElementById('ds-score-pill-value-tf') as HTMLInputElement | null;
    const leadingInput = document.getElementById('ds-score-pill-leading-tf') as HTMLInputElement | null;
    const trailingInput = document.getElementById('ds-score-pill-trailing-tf') as HTMLInputElement | null;
    const minusBtn = document.getElementById('ds-score-pill-minus');
    const plusBtn = document.getElementById('ds-score-pill-plus');
    if (!page || !root || !pill || !valueInput || !leadingInput || !trailingInput) return;

    bindFieldClear(page);

    const iconStart = pill.querySelector('[data-ds-icon-start]') as HTMLElement;
    const leadingEl = pill.querySelector('[data-ds-leading]') as HTMLElement;
    const trailingEl = pill.querySelector('[data-ds-trailing]') as HTMLElement;
    const variantLabel = page.querySelector('[data-ds-dd="variant-label"]');
    const sizeLabel = page.querySelector('[data-ds-dd="size-label"]');
    const iconLabel = page.querySelector('[data-ds-dd="icon-label"]');
    const accentRow = page.querySelector<HTMLTableRowElement>('tr.js-ds-accent-token-row');
    const accentLabel = page.querySelector('[data-ds-dd="accent-token-label"]');

    const map: Record<string, string> = { none: '', ...takeInjectedIconHtmlMap('__dsShowcaseScorePillIconHtmlMap') };

    let variant = 'primary';
    let size = 'm';
    let iconKey = 'none';
    let accentToken: AccentTok = 'container-accent-blue';
    let firstValueApply = true;

    function applyIcon() {
      const html = map[iconKey] || '';
      if (!iconStart) return;
      if (!html) {
        iconStart.innerHTML = '';
        return;
      }
      const isz = iconSizeForBtn(size);
      const istyle = iconKey.endsWith('-fill') ? 'fill' : 'outline';
      iconStart.innerHTML = `<span class="ui-icon" data-size="${isz}" data-style="${istyle}">${html}</span>`;
    }

    function applyChrome() {
      pill.setAttribute('data-variant', variant);
      pill.setAttribute('data-size', size);
      pill.className = ['ui-btn', 'ui-score-pill', typoForSize(size)].join(' ');
      if (variantLabel) variantLabel.textContent = variant.charAt(0).toUpperCase() + variant.slice(1);
      if (sizeLabel) sizeLabel.textContent = size.toUpperCase();
      if (iconLabel) {
        iconLabel.textContent = iconKey === 'none' ? 'None' : `icon-${iconKey}`;
      }
      if (accentRow) accentRow.hidden = variant !== 'accent';
      if (variant === 'accent') {
        pill.style.setProperty('background', accentTokenCssVar(accentToken));
      } else {
        pill.style.removeProperty('background');
      }
      if (accentLabel) accentLabel.textContent = accentTokenMenuLabel(accentToken);
      applyIcon();
    }

    function readValueFromInput(): number {
      return parseNonNegInt(valueInput.value);
    }

    function syncLabels() {
      const lead = leadingInput.value.trim();
      const trail = trailingInput.value.trim();
      leadingEl.textContent = lead;
      trailingEl.textContent = trail;
      leadingEl.hidden = !lead;
      trailingEl.hidden = !trail;
    }

    function applyValue(animate: boolean) {
      const v = readValueFromInput();
      syncLabels();
      setScorePillValue(pill, v, { animate: animate && !firstValueApply });
      firstValueApply = false;
    }

    page.querySelectorAll('[data-ds-pick="variant"]').forEach((el) => {
      el.addEventListener('click', () => {
        const v = (el as HTMLElement).dataset.value;
        if (v) {
          variant = v;
          applyChrome();
        }
      });
    });
    page.querySelectorAll('[data-ds-pick="size"]').forEach((el) => {
      el.addEventListener('click', () => {
        const v = (el as HTMLElement).dataset.value;
        if (v) {
          size = v;
          applyChrome();
        }
      });
    });
    page.querySelectorAll('[data-ds-pick="icon"]').forEach((el) => {
      el.addEventListener('click', () => {
        const v = (el as HTMLElement).dataset.value;
        if (v) {
          iconKey = v;
          applyChrome();
        }
      });
    });
    page.querySelectorAll('[data-ds-pick="accent-token"]').forEach((el) => {
      el.addEventListener('click', () => {
        const v = (el as HTMLElement).dataset.value;
        if (v) {
          accentToken = v as AccentTok;
          applyChrome();
        }
      });
    });

    valueInput.addEventListener('input', () => applyValue(true));
    leadingInput.addEventListener('input', () => {
      syncLabels();
      const v = readValueFromInput();
      setScorePillValue(pill, v, { animate: false });
    });
    trailingInput.addEventListener('input', () => {
      syncLabels();
      const v = readValueFromInput();
      setScorePillValue(pill, v, { animate: false });
    });

    minusBtn?.addEventListener('click', () => {
      const v = Math.max(0, readValueFromInput() - 1);
      valueInput.value = String(v);
      applyValue(true);
    });
    plusBtn?.addEventListener('click', () => {
      const v = readValueFromInput() + 1;
      valueInput.value = String(v);
      applyValue(true);
    });

    applyChrome();
    firstValueApply = true;
    syncLabels();
    applyValue(false);

    page.querySelector('.js-ds-showcase-copy')?.addEventListener('click', async () => {
      const v = readValueFromInput();
      const text = buildCopyPrompt({
        component: 'ScorePillCounter',
        props: {
          variant,
          size,
          value: v,
          leadingLabel: leadingInput.value.trim() || undefined,
          trailingLabel: trailingInput.value.trim() || undefined,
          iconStart: iconKey === 'none' ? 'none' : `icon-${iconKey}.svg`,
          ...(variant === 'accent' ? { accentContainer: accentToken } : {}),
        },
        note: 'Import setScorePillValue from components/score-pill-counter and call it when the score changes.',
      });
      try {
        await navigator.clipboard.writeText(text);
      } catch {
        /* ignore */
      }
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
</script>

<style>
  .ds-score-pill-preview-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-12);
  }

  .ds-score-pill-stepper {
    display: inline-flex;
    align-items: center;
    gap: var(--space-8);
  }
</style>
