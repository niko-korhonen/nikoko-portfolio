---
import Toggle from '../../components/Toggle.astro';
import ButtonDropdown from '../../components/ButtonDropdown.astro';
import MenuDropdown from '../../components/MenuDropdown.astro';
import MenuItemAction from '../../components/MenuItemAction.astro';
import ComponentShowcasePage from '../templates/ComponentShowcasePage.astro';
import ShowcasePreviewCard from '../templates/ShowcasePreviewCard.astro';
import ShowcaseControlsTable from '../templates/ShowcaseControlsTable.astro';
import ShowcaseControlRow from '../templates/ShowcaseControlRow.astro';
import ShowcaseCopyPrompt from '../templates/ShowcaseCopyPrompt.astro';

const states = [
  { id: 'unchecked', label: 'Off' },
  { id: 'checked', label: 'On' },
] as const;
---

<ComponentShowcasePage
  title="Toggle"
  headingId="toggle-heading"
  description="Binary on/off control using a switch. Use a visible label in layout beside the control; the component itself is icon-only with an accessible name from context."
>
  <ShowcasePreviewCard>
    <div data-ds-demo="toggle">
      <Toggle name="ds-toggle-demo" value="on" />
    </div>
  </ShowcasePreviewCard>

  <ShowcaseControlsTable>
    <ShowcaseControlRow label="State">
      <MenuDropdown>
        <ButtonDropdown slot="trigger" variant="secondary" size="s" type="button">
          <span data-ds-dd="state-label">Off</span>
        </ButtonDropdown>
        {
          states.map((s) => (
            <MenuItemAction type="button" data-ds-pick="state" data-value={s.id}>
              {s.label}
            </MenuItemAction>
          ))
        }
      </MenuDropdown>
    </ShowcaseControlRow>
    <ShowcaseControlRow label="Disabled">
      <div class="ds-showcase-toggle-wrap" data-ds-toggle="disabled">
        <Toggle name="ds-toggle-disabled-ctrl" />
      </div>
    </ShowcaseControlRow>
  </ShowcaseControlsTable>

  <ShowcaseCopyPrompt componentLabel="Toggle" />
</ComponentShowcasePage>

<script>
  import { buildCopyPrompt } from '../copy-prompt';
  import { getShowcasePage } from '../showcase-ui';

  function init() {
    const root = document.querySelector('[data-ds-demo="toggle"]');
    const page = getShowcasePage(root);
    const input = root?.querySelector<HTMLInputElement>('.ui-toggle__input');
    const stateLabel = page?.querySelector('[data-ds-dd="state-label"]');
    const disabledCb = page?.querySelector<HTMLInputElement>(
      '[data-ds-toggle="disabled"] input[role="switch"]',
    );
    if (!page || !root || !input) return;

    function apply() {
      input.checked = stateLabel?.textContent?.trim() === 'On';
      input.disabled = Boolean(disabledCb?.checked);
    }

    page.querySelectorAll('[data-ds-pick="state"]').forEach((el) => {
      el.addEventListener('click', () => {
        const v = (el as HTMLElement).dataset.value;
        if (v === 'checked' || v === 'unchecked') {
          if (stateLabel) stateLabel.textContent = v === 'checked' ? 'On' : 'Off';
          apply();
        }
      });
    });
    disabledCb?.addEventListener('change', apply);
    apply();

    page.querySelector('.js-ds-showcase-copy')?.addEventListener('click', async () => {
      const text = buildCopyPrompt({
        component: 'Toggle',
        props: {
          checked: input.checked,
          disabled: Boolean(disabledCb?.checked),
        },
      });
      try {
        await navigator.clipboard.writeText(text);
      } catch {
        /* ignore */
      }
    });
  }

  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', init);
  else init();
</script>
