---
import ButtonDropdown from '../../components/ButtonDropdown.astro';
import MenuDropdown from '../../components/MenuDropdown.astro';
import MenuItemAction from '../../components/MenuItemAction.astro';
import ComponentShowcasePage from '../templates/ComponentShowcasePage.astro';
import ShowcasePreviewCard from '../templates/ShowcasePreviewCard.astro';
import ShowcaseControlsTable from '../templates/ShowcaseControlsTable.astro';
import ShowcaseControlRow from '../templates/ShowcaseControlRow.astro';
import ShowcaseCopyPrompt from '../templates/ShowcaseCopyPrompt.astro';
import { radiusTokens } from '../data';
---

<ComponentShowcasePage
  title="Radius"
  headingId="radius-heading"
  description="Corner radius tokens from none through highest. Surfaces, buttons, and fields consume these via shared variables for consistent rounding."
>
  <ShowcasePreviewCard>
    <div data-ds-demo="radius" style="width:100%;max-width:16rem;">
      <div
        class="ds-radius-preview"
        data-ds-radius-box
        style="border-radius: var(--radius-medium); background: var(--color-surface-elevation); border: 1px solid var(--color-outline-tertiary); height: 6rem;"
      >
      </div>
      <code class="text-code-xs-plain" style="margin-top:var(--space-12);display:block;text-align:center;" data-ds-radius-code>
        --radius-medium
      </code>
    </div>
  </ShowcasePreviewCard>

  <ShowcaseControlsTable>
    <ShowcaseControlRow label="Token">
      <MenuDropdown>
        <ButtonDropdown slot="trigger" variant="secondary" size="s" type="button">
          <span data-ds-dd="radius-label">medium</span>
        </ButtonDropdown>
        {
          radiusTokens.map((t) => (
            <MenuItemAction type="button" data-ds-pick="radius" data-value={t}>
              {t}
            </MenuItemAction>
          ))
        }
      </MenuDropdown>
    </ShowcaseControlRow>
  </ShowcaseControlsTable>

  <ShowcaseCopyPrompt componentLabel="Radius" />
</ComponentShowcasePage>

<script>
  import { buildCopyPrompt } from '../copy-prompt';
  import { getShowcasePage } from '../showcase-ui';

  function init() {
    const page = getShowcasePage();
    const box = document.querySelector('[data-ds-radius-box]');
    const codeEl = document.querySelector('[data-ds-radius-code]');
    const label = page?.querySelector('[data-ds-dd="radius-label"]');
    if (!page || !box || !codeEl) return;

    let token = 'medium';

    function apply() {
      const v = `var(--radius-${token})`;
      (box as HTMLElement).style.borderRadius = v;
      codeEl.textContent = `--radius-${token}`;
      if (label) label.textContent = token;
    }

    page.querySelectorAll('[data-ds-pick="radius"]').forEach((el) => {
      el.addEventListener('click', () => {
        const v = (el as HTMLElement).dataset.value;
        if (v) {
          token = v;
          apply();
        }
      });
    });
    apply();

    page.querySelector('.js-ds-showcase-copy')?.addEventListener('click', async () => {
      const text = buildCopyPrompt({
        component: 'Radius',
        props: { token: `--radius-${token}` },
      });
      try {
        await navigator.clipboard.writeText(text);
      } catch {
        /* ignore */
      }
    });
  }

  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', init);
  else init();
</script>
