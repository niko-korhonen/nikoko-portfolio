---
import SegmentControl from '../../components/SegmentControl.astro';
import ButtonDropdown from '../../components/ButtonDropdown.astro';
import MenuDropdown from '../../components/MenuDropdown.astro';
import MenuItemAction from '../../components/MenuItemAction.astro';
import ComponentShowcasePage from '../templates/ComponentShowcasePage.astro';
import ShowcasePreviewCard from '../templates/ShowcasePreviewCard.astro';
import ShowcaseControlsTable from '../templates/ShowcaseControlsTable.astro';
import ShowcaseControlRow from '../templates/ShowcaseControlRow.astro';
import ShowcaseCopyPrompt from '../templates/ShowcaseCopyPrompt.astro';
import { segmentShowcaseItems } from '../data';

const sizes = ['l', 'm', 's'] as const;
const semantics = [
  { id: 'radiogroup' as const, label: 'Radiogroup' },
  { id: 'tablist' as const, label: 'Tab list' },
];
---

<ComponentShowcasePage
  title="SegmentControl"
  headingId="segment-control-heading"
  description="Pill-style single selection with a sliding indicator. Use semantic radiogroup for forms; tablist when pairing with tab panels. Icons and labels follow the same content modes as buttons."
>
  <ShowcasePreviewCard>
    <div data-ds-demo="segment">
      {
        semantics.map((sem) =>
          sizes.map((sz) => (
            <div
              class:list={['ds-seg-tier', !(sem.id === 'radiogroup' && sz === 'm') && 'ds-seg-tier--hidden']}
              data-seg-key={`${sem.id}-${sz}`}
            >
              <SegmentControl
                semantic={sem.id}
                size={sz}
                name={`demo-segment-${sem.id}-${sz}`}
                ariaLabel={`Segment demo ${sem.id} ${sz}`}
                defaultValue="icon-label"
                items={[...segmentShowcaseItems]}
              />
            </div>
          )),
        )
      }
    </div>
  </ShowcasePreviewCard>

  <ShowcaseControlsTable>
    <ShowcaseControlRow label="Size">
      <MenuDropdown>
        <ButtonDropdown slot="trigger" variant="secondary" size="s" type="button">
          <span data-ds-dd="size-label">M</span>
        </ButtonDropdown>
        {
          sizes.map((s) => (
            <MenuItemAction type="button" data-ds-pick="size" data-value={s}>
              {s.toUpperCase()}
            </MenuItemAction>
          ))
        }
      </MenuDropdown>
    </ShowcaseControlRow>
    <ShowcaseControlRow label="Semantic">
      <MenuDropdown>
        <ButtonDropdown slot="trigger" variant="secondary" size="s" type="button">
          <span data-ds-dd="semantic-label">Radiogroup</span>
        </ButtonDropdown>
        {
          semantics.map((s) => (
            <MenuItemAction type="button" data-ds-pick="semantic" data-value={s.id}>
              {s.label}
            </MenuItemAction>
          ))
        }
      </MenuDropdown>
    </ShowcaseControlRow>
  </ShowcaseControlsTable>

  <ShowcaseCopyPrompt componentLabel="SegmentControl" />
</ComponentShowcasePage>

<style>
  .ds-seg-tier--hidden {
    display: none;
  }
</style>

<script>
  import { buildCopyPrompt } from '../copy-prompt';
  import { getShowcasePage } from '../showcase-ui';

  function init() {
    const page = getShowcasePage();
    const root = document.querySelector('[data-ds-demo="segment"]');
    const sizeLabel = page?.querySelector('[data-ds-dd="size-label"]');
    const semanticLabel = page?.querySelector('[data-ds-dd="semantic-label"]');
    if (!page || !root) return;

    let size: 'l' | 'm' | 's' = 'm';
    let semantic: 'radiogroup' | 'tablist' = 'radiogroup';

    function showTier() {
      const key = `${semantic}-${size}`;
      root.querySelectorAll('[data-seg-key]').forEach((el) => {
        const k = (el as HTMLElement).dataset.segKey;
        (el as HTMLElement).classList.toggle('ds-seg-tier--hidden', k !== key);
      });
      if (sizeLabel) sizeLabel.textContent = size.toUpperCase();
      if (semanticLabel)
        semanticLabel.textContent = semantic === 'tablist' ? 'Tab list' : 'Radiogroup';
    }

    page.querySelectorAll('[data-ds-pick="size"]').forEach((el) => {
      el.addEventListener('click', () => {
        const v = (el as HTMLElement).dataset.value as 'l' | 'm' | 's' | undefined;
        if (v) {
          size = v;
          showTier();
        }
      });
    });

    page.querySelectorAll('[data-ds-pick="semantic"]').forEach((el) => {
      el.addEventListener('click', () => {
        const v = (el as HTMLElement).dataset.value as 'radiogroup' | 'tablist' | undefined;
        if (v) {
          semantic = v;
          showTier();
        }
      });
    });

    showTier();

    page.querySelector('.js-ds-showcase-copy')?.addEventListener('click', async () => {
      const text = buildCopyPrompt({
        component: 'SegmentControl',
        props: {
          size,
          semantic,
          defaultValue: 'icon-label',
        },
        note: 'Pass items array with value, optional icon, label, content mode, and aria labels for icon-only cells.',
      });
      try {
        await navigator.clipboard.writeText(text);
      } catch {
        /* ignore */
      }
    });
  }

  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', init);
  else init();
</script>
