---
import ButtonDropdown from '../../components/ButtonDropdown.astro';
import MenuDropdown from '../../components/MenuDropdown.astro';
import MenuItemAction from '../../components/MenuItemAction.astro';
import ComponentShowcasePage from '../templates/ComponentShowcasePage.astro';
import ShowcasePreviewCard from '../templates/ShowcasePreviewCard.astro';
import ShowcaseControlsTable from '../templates/ShowcaseControlsTable.astro';
import ShowcaseControlRow from '../templates/ShowcaseControlRow.astro';
import ShowcaseCopyPrompt from '../templates/ShowcaseCopyPrompt.astro';
import { spacingTokens } from '../data';
---

<ComponentShowcasePage
  title="Spacing"
  headingId="spacing-heading"
  description="Fixed spacing scale based on spacing tokens. Use them for gaps, padding, and layout rhythm instead of arbitrary pixel values."
>
  <ShowcasePreviewCard>
    <div data-ds-demo="spacing" style="width:100%;max-width:22rem;">
      <div class="ds-spacing-row" data-ds-spacing-row style="display:flex;gap:var(--space-16);align-items:center;">
        <span class="lp-demo-pill text-label-s-plain">A</span>
        <span class="lp-demo-pill text-label-s-plain">B</span>
      </div>
      <code class="text-code-xs-plain" style="margin-top:var(--space-12);display:block;text-align:center;" data-ds-spacing-code>
        gap: var(--space-16)
      </code>
    </div>
  </ShowcasePreviewCard>

  <ShowcaseControlsTable>
    <ShowcaseControlRow label="Token">
      <MenuDropdown>
        <ButtonDropdown slot="trigger" variant="secondary" size="s" type="button">
          <span data-ds-dd="space-label">space-16</span>
        </ButtonDropdown>
        {
          spacingTokens.map((t) => (
            <MenuItemAction type="button" data-ds-pick="space" data-value={t}>
              {t}
            </MenuItemAction>
          ))
        }
      </MenuDropdown>
    </ShowcaseControlRow>
  </ShowcaseControlsTable>

  <ShowcaseCopyPrompt componentLabel="Spacing" />
</ComponentShowcasePage>

<script>
  import { buildCopyPrompt } from '../copy-prompt';
  import { getShowcasePage } from '../showcase-ui';

  function init() {
    const root = document.querySelector('[data-ds-demo="spacing"]');
    const page = getShowcasePage(root);
    const row = root?.querySelector('[data-ds-spacing-row]') as HTMLElement | null;
    const codeEl = root?.querySelector('[data-ds-spacing-code]');
    const label = page?.querySelector('[data-ds-dd="space-label"]');
    if (!page || !row || !codeEl) return;

    let token = 'space-16';

    function apply() {
      row.style.gap = `var(--${token})`;
      codeEl.textContent = `gap: var(--${token})`;
      if (label) label.textContent = token;
    }

    document.querySelectorAll('[data-ds-pick="space"]').forEach((el) => {
      el.addEventListener('click', () => {
        const v = (el as HTMLElement).dataset.value;
        if (v) {
          token = v;
          apply();
        }
      });
    });
    apply();

    page.querySelector('.js-ds-showcase-copy')?.addEventListener('click', async () => {
      const text = buildCopyPrompt({
        component: 'Spacing',
        props: { token: `--${token}` },
      });
      try {
        await navigator.clipboard.writeText(text);
      } catch {
        /* ignore */
      }
    });
  }

  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', init);
  else init();
</script>
