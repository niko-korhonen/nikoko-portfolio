---
import AnchoredToast from '../../components/AnchoredToast.astro';
import Button from '../../components/Button.astro';
import ButtonDropdown from '../../components/ButtonDropdown.astro';
import MenuDropdown from '../../components/MenuDropdown.astro';
import MenuItemAction from '../../components/MenuItemAction.astro';
import ShowcaseTextFieldControl from '../templates/ShowcaseTextFieldControl.astro';
import ComponentShowcasePage from '../templates/ComponentShowcasePage.astro';
import ShowcasePreviewCard from '../templates/ShowcasePreviewCard.astro';
import ShowcaseControlsTable from '../templates/ShowcaseControlsTable.astro';
import ShowcaseControlRow from '../templates/ShowcaseControlRow.astro';
import ShowcaseCopyPrompt from '../templates/ShowcaseCopyPrompt.astro';

const variants = ['success', 'error', 'info', 'neutral'] as const;
const positions = ['top', 'bottom', 'left', 'right'] as const;
const aligns = ['start', 'center', 'end'] as const;
---

<ComponentShowcasePage
  title="AnchoredToast"
  headingId="anchored-toast-heading"
  description="Compact feedback anchored to a trigger; placement matches Tooltip and MenuDropdown. Queues respect a max visible count; success, error, and neutral use distinct motion. Click the trigger to enqueue a toast with the selected settings."
>
  <ShowcasePreviewCard>
    <div data-ds-demo="anchored-toast">
      <AnchoredToast variant="success" message="Saved" position="top" align="center">
        <Button slot="trigger" variant="primary" size="m">Show toast</Button>
      </AnchoredToast>
    </div>
  </ShowcasePreviewCard>

  <ShowcaseControlsTable>
    <ShowcaseControlRow label="Variant">
      <MenuDropdown>
        <ButtonDropdown slot="trigger" variant="secondary" size="s" type="button">
          <span data-ds-dd="var-label">Success</span>
        </ButtonDropdown>
        {
          variants.map((v) => (
            <MenuItemAction type="button" data-ds-pick="variant" data-value={v}>
              {v.charAt(0).toUpperCase() + v.slice(1)}
            </MenuItemAction>
          ))
        }
      </MenuDropdown>
    </ShowcaseControlRow>
    <ShowcaseControlRow label="Position">
      <MenuDropdown>
        <ButtonDropdown slot="trigger" variant="secondary" size="s" type="button">
          <span data-ds-dd="pos-label">Top</span>
        </ButtonDropdown>
        {
          positions.map((p) => (
            <MenuItemAction type="button" data-ds-pick="position" data-value={p}>
              {p.charAt(0).toUpperCase() + p.slice(1)}
            </MenuItemAction>
          ))
        }
      </MenuDropdown>
    </ShowcaseControlRow>
    <ShowcaseControlRow label="Align">
      <MenuDropdown>
        <ButtonDropdown slot="trigger" variant="secondary" size="s" type="button">
          <span data-ds-dd="align-label">Center</span>
        </ButtonDropdown>
        {
          aligns.map((a) => (
            <MenuItemAction type="button" data-ds-pick="align" data-value={a}>
              {a.charAt(0).toUpperCase() + a.slice(1)}
            </MenuItemAction>
          ))
        }
      </MenuDropdown>
    </ShowcaseControlRow>
    <ShowcaseControlRow label="Message">
      <ShowcaseTextFieldControl id="ds-at-msg" ariaLabel="Toast message" placeholder="Saved" />
    </ShowcaseControlRow>
  </ShowcaseControlsTable>

  <ShowcaseCopyPrompt componentLabel="AnchoredToast" />
</ComponentShowcasePage>

<script>
  import { buildCopyPrompt } from '../copy-prompt';
  import { bindFieldClear, getShowcasePage } from '../showcase-ui';

  function init() {
    const root = document.querySelector('[data-ds-demo="anchored-toast"]');
    const page = getShowcasePage(root);
    const toastRoot = root?.querySelector<HTMLElement>('[data-anchored-toast]');
    const trigger = root?.querySelector<HTMLElement>('[data-anchored-toast-trigger]');
    const stack = root?.querySelector<HTMLElement>('[data-anchored-toast-stack]');
    const msgCtrl = document.getElementById('ds-at-msg') as HTMLInputElement | null;
    const varLabel = page?.querySelector('[data-ds-dd="var-label"]');
    const posLabel = page?.querySelector('[data-ds-dd="pos-label"]');
    const alignLabel = page?.querySelector('[data-ds-dd="align-label"]');
    if (!page || !toastRoot || !trigger || !stack || !msgCtrl) return;
    bindFieldClear(page);

    let variant: (typeof variants)[number] = 'success';
    let position: (typeof positions)[number] = 'top';
    let align: (typeof aligns)[number] = 'center';

    function apply() {
      trigger.dataset.anchoredToastVariant = variant;
      trigger.dataset.anchoredToastMessage = msgCtrl.value.trim() || 'Label';
      stack.setAttribute('data-popover-position', position);
      stack.setAttribute('data-popover-align', align);
      if (varLabel) varLabel.textContent = variant.charAt(0).toUpperCase() + variant.slice(1);
      if (posLabel) posLabel.textContent = position.charAt(0).toUpperCase() + position.slice(1);
      if (alignLabel) alignLabel.textContent = align.charAt(0).toUpperCase() + align.slice(1);
    }

    page.querySelectorAll('[data-ds-pick="variant"]').forEach((el) => {
      el.addEventListener('click', () => {
        const v = (el as HTMLElement).dataset.value as (typeof variants)[number] | undefined;
        if (v) {
          variant = v;
          apply();
        }
      });
    });
    page.querySelectorAll('[data-ds-pick="position"]').forEach((el) => {
      el.addEventListener('click', () => {
        const v = (el as HTMLElement).dataset.value as (typeof positions)[number] | undefined;
        if (v) {
          position = v;
          apply();
        }
      });
    });
    page.querySelectorAll('[data-ds-pick="align"]').forEach((el) => {
      el.addEventListener('click', () => {
        const v = (el as HTMLElement).dataset.value as (typeof aligns)[number] | undefined;
        if (v) {
          align = v;
          apply();
        }
      });
    });
    msgCtrl.addEventListener('input', apply);
    apply();

    page.querySelector('.js-ds-showcase-copy')?.addEventListener('click', async () => {
      const text = buildCopyPrompt({
        component: 'AnchoredToast',
        props: {
          variant,
          message: msgCtrl.value.trim() || 'Label',
          position,
          align,
        },
      });
      try {
        await navigator.clipboard.writeText(text);
      } catch {
        /* ignore */
      }
    });
  }

  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', init);
  else init();
</script>
