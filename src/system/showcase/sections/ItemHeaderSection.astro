---
import ItemHeader from '../../components/ItemHeader.astro';
import Stack from '../../primitives/Stack.astro';
import ComponentShowcasePage from '../templates/ComponentShowcasePage.astro';
import ShowcasePreviewCard from '../templates/ShowcasePreviewCard.astro';
import ShowcaseControlsTable from '../templates/ShowcaseControlsTable.astro';
import ShowcaseControlRow from '../templates/ShowcaseControlRow.astro';
import ShowcaseCopyPrompt from '../templates/ShowcaseCopyPrompt.astro';
---

<ComponentShowcasePage
  title="ItemHeader"
  headingId="item-header-heading"
  description="Section label for stacked lists. Uses label S typography; pair with ItemDivider and ItemAction or ItemStatic rows below."
>
  <ShowcasePreviewCard>
    <div class="ds-item-demo" style="width:100%;max-width:28rem;">
      <Stack gap="space-2" align="stretch">
        <ItemHeader>Section</ItemHeader>
      </Stack>
    </div>
  </ShowcasePreviewCard>

  <ShowcaseControlsTable>
    <ShowcaseControlRow label="Usage">
      <p class="text-body-xs-plain" style="margin:0">
        Use as a heading row before grouped items. Children are plain text or inline markup.
      </p>
    </ShowcaseControlRow>
  </ShowcaseControlsTable>

  <ShowcaseCopyPrompt componentLabel="ItemHeader" />
</ComponentShowcasePage>

<script>
  import { buildCopyPrompt } from '../copy-prompt';
  import { getShowcasePage } from '../showcase-ui';

  function init() {
    const page = getShowcasePage();
    if (!page) return;

    page.querySelector('.js-ds-showcase-copy')?.addEventListener('click', async () => {
      const text = buildCopyPrompt({
        component: 'ItemHeader',
        props: { children: 'Section title' },
      });
      try {
        await navigator.clipboard.writeText(text);
      } catch {
        /* ignore */
      }
    });
  }

  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', init);
  else init();
</script>
