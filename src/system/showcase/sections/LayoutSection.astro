---
import Cluster from '../../primitives/Cluster.astro';
import Container from '../../primitives/Container.astro';
import Inline from '../../primitives/Inline.astro';
import Section from '../../primitives/Section.astro';
import Stack from '../../primitives/Stack.astro';
import Surface from '../../primitives/Surface.astro';
---

<section class="section" aria-labelledby="layout-primitives-heading">
  <h2 class="text-headline-s-emphasized section__title" id="layout-primitives-heading">Layout primitives</h2>
  <p class="text-body-s-plain section__note">
    Structural building blocks from <code class="code-inline">src/system/primitives/</code>. Pass spacing token
    names (e.g. <code class="code-inline">gap=&quot;space-8&quot;</code>, <code class="code-inline">padding=&quot;space-16&quot;</code>).
  </p>

  <div class="subsection">
    <h3 class="text-label-l-emphasized subsection__title">Container</h3>
    <p class="text-body-s-plain subsection__hint">Centers content, horizontal padding, max width.</p>
    <Stack gap="space-8">
      <Container size="default">
        <div class="lp-demo-cell text-label-s-plain">size=&quot;default&quot; (max: --layout-container-max)</div>
      </Container>
      <Container size="wide">
        <div class="lp-demo-cell text-label-s-plain">size=&quot;wide&quot; (max: --layout-container-max-wide)</div>
      </Container>
    </Stack>
  </div>

  <div class="subsection">
    <h3 class="text-label-l-emphasized subsection__title">Stack</h3>
    <p class="text-body-s-plain subsection__hint">Vertical flex; gap and align-items.</p>
    <Stack gap="space-8" align="stretch">
      <div class="lp-demo-cell text-body-s-plain">Row one</div>
      <div class="lp-demo-cell text-body-s-plain">Row two</div>
      <div class="lp-demo-cell text-body-s-plain">Row three</div>
    </Stack>
  </div>

  <div class="subsection">
    <h3 class="text-label-l-emphasized subsection__title">Inline</h3>
    <p class="text-body-s-plain subsection__hint">Horizontal row; gap, align, justify.</p>
    <Inline gap="space-8" align="center" justify="between">
      <span class="text-label-s-plain lp-demo-pill">Left</span>
      <span class="text-label-s-plain lp-demo-pill">Center area</span>
      <span class="text-label-s-plain lp-demo-pill">Right</span>
    </Inline>
  </div>

  <div class="subsection">
    <h3 class="text-label-l-emphasized subsection__title">Cluster</h3>
    <p class="text-body-s-plain subsection__hint">Wraps items to new rows.</p>
    <Cluster gap="space-8" align="center">
      <span class="text-label-s-plain lp-demo-pill">One</span>
      <span class="text-label-s-plain lp-demo-pill">Two</span>
      <span class="text-label-s-plain lp-demo-pill">Three</span>
      <span class="text-label-s-plain lp-demo-pill">Four</span>
      <span class="text-label-s-plain lp-demo-pill">Five</span>
    </Cluster>
  </div>

  <div class="subsection">
    <h3 class="text-label-l-emphasized subsection__title">Section</h3>
    <p class="text-body-s-plain subsection__hint">Padding and optional surface background.</p>
    <Section padding="space-16" surface="elevation">
      <p class="text-body-s-plain">padding=&quot;space-16&quot; · surface=&quot;elevation&quot;</p>
    </Section>
  </div>

  <div class="subsection">
    <h3 class="text-label-l-emphasized subsection__title">Surface</h3>
    <p class="text-body-s-plain subsection__hint">Surface token, padding, radius.</p>
    <Surface variant="floating" padding="space-16" radius="medium">
      <p class="text-body-s-plain">variant=&quot;floating&quot; · padding=&quot;space-16&quot; · radius=&quot;medium&quot;</p>
    </Surface>
  </div>

  <div class="subsection">
    <h3 class="text-label-l-emphasized subsection__title">Composition</h3>
    <p class="text-body-s-plain subsection__hint">Container → Stack → Surface.</p>
    <Container size="default">
      <Stack gap="space-16">
        <Surface variant="elevation" padding="space-8" radius="low">
          <p class="text-body-s-plain">Nested example</p>
        </Surface>
      </Stack>
    </Container>
  </div>
</section>
