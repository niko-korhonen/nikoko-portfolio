---
import Button from '../../components/Button.astro';
import ButtonIcon from '../../components/ButtonIcon.astro';
import ButtonDropdown from '../../components/ButtonDropdown.astro';
import MenuDropdown from '../../components/MenuDropdown.astro';
import MenuItemAction from '../../components/MenuItemAction.astro';
import ModalDialog from '../../components/ModalDialog.astro';
import Toggle from '../../components/Toggle.astro';
import Icon from '../../icons/Icon.astro';
import ComponentShowcasePage from '../templates/ComponentShowcasePage.astro';
import ShowcasePreviewCard from '../templates/ShowcasePreviewCard.astro';
import ShowcaseControlsTable from '../templates/ShowcaseControlsTable.astro';
import ShowcaseControlRow from '../templates/ShowcaseControlRow.astro';
import ShowcaseCopyPrompt from '../templates/ShowcaseCopyPrompt.astro';
import ShowcaseTextFieldControl from '../templates/ShowcaseTextFieldControl.astro';
import ShowcaseIconMenuItems from '../templates/ShowcaseIconMenuItems.astro';
import { getAllIconVariantMenuEntries, loadAllIconVariantInlineMap } from '../showcase-icons';

const iconVariantMenu = getAllIconVariantMenuEntries();
const iconHtmlMap: Record<string, string> = loadAllIconVariantInlineMap();
const defaultHeroKey =
  iconVariantMenu.find((e) => e.key === 'placeholder-outline')?.key ??
  iconVariantMenu[0]?.key ??
  'placeholder-outline';

function parseIconVariantKey(key: string): { name: string; style: 'outline' | 'fill' } {
  const m = /^(.*)-(outline|fill)$/.exec(key);
  if (!m) return { name: 'placeholder', style: 'outline' };
  return { name: m[1], style: m[2] as 'outline' | 'fill' };
}

const defaultHeroParts = parseIconVariantKey(defaultHeroKey);
const defaultHeroMenuLabel =
  iconVariantMenu.find((e) => e.key === defaultHeroKey)?.menuLabel ?? `icon-${defaultHeroKey}`;

const layoutLabels: Record<string, string> = {
  centered: 'Centered',
  footer: 'Footer actions',
};

const toolbarAlignLabels: Record<string, string> = {
  start: 'Start',
  end: 'End',
};
---

<ComponentShowcasePage
  title="ModalDialog"
  headingId="modal-dialog-heading"
  description="Native &lt;dialog&gt; with overlay token, optional hero icon (L), and centered or footer action layouts. The preview uses show() inside the card so the dialog stays scoped; pick None under Hero icon to hide the hero region (like showHero false). Controls mirror ModalDialog props and slots without changing the component API."
>
  <ShowcasePreviewCard class="ds-modal-showcase-preview">
    <div class="ds-modal-preview-cage" data-ds-demo="modal">
      <p class="text-body-xs-plain" style="margin:0;color:var(--color-content-tertiary);">
        Open sample — stays inside this preview; overlay is demo-only.
      </p>
      <button
        type="button"
        class="ui-btn ui-focus-ring text-label-s-plain"
        data-variant="primary"
        data-size="m"
        id="ds-modal-open"
      >
        Open dialog
      </button>

      <ModalDialog id="demo-modal-centered" class="ds-modal-dialog-scoped" layout="centered">
        <ButtonIcon slot="toolbar" variant="ghost" size="m" label="Close dialog" dialogClose>
          <Icon name="cross" style="outline" size="s" />
        </ButtonIcon>
        <Icon slot="hero" name={defaultHeroParts.name} style={defaultHeroParts.style} size="l" />
        <span slot="title">Dialog title</span>
        <span slot="description">Supporting description.</span>
        <Button slot="center" variant="primary" size="l" dialogClose>Continue</Button>
      </ModalDialog>

      <ModalDialog id="demo-modal-footer" class="ds-modal-dialog-scoped" layout="footer">
        <ButtonIcon slot="toolbar" variant="ghost" size="m" label="Close dialog" dialogClose>
          <Icon name="cross" style="outline" size="s" />
        </ButtonIcon>
        <Icon slot="hero" name={defaultHeroParts.name} style={defaultHeroParts.style} size="l" />
        <span slot="title">Dialog title</span>
        <span slot="description">Supporting description.</span>
        <Button slot="footer" variant="primary" size="l" dialogClose>Primary</Button>
        <Button slot="footer" variant="secondary" size="l" dialogClose>Secondary</Button>
      </ModalDialog>
    </div>
  </ShowcasePreviewCard>

  <ShowcaseControlsTable>
    <ShowcaseControlRow label="Layout">
      <MenuDropdown>
        <ButtonDropdown slot="trigger" variant="secondary" size="s" type="button">
          <span data-ds-dd="modal-layout-label">{layoutLabels.centered}</span>
        </ButtonDropdown>
        <MenuItemAction type="button" data-ds-pick="modal-layout" data-value="centered">
          {layoutLabels.centered}
        </MenuItemAction>
        <MenuItemAction type="button" data-ds-pick="modal-layout" data-value="footer">
          {layoutLabels.footer}
        </MenuItemAction>
      </MenuDropdown>
    </ShowcaseControlRow>
    <ShowcaseControlRow label="Title">
      <ShowcaseTextFieldControl id="ds-modal-title" ariaLabel="Dialog title" placeholder="Dialog title" value="Dialog title" />
    </ShowcaseControlRow>
    <ShowcaseControlRow label="Description">
      <ShowcaseTextFieldControl
        id="ds-modal-desc"
        ariaLabel="Dialog description"
        placeholder="Supporting description"
        value="Supporting description."
      />
    </ShowcaseControlRow>
    <ShowcaseControlRow label="Hero icon">
      <MenuDropdown>
        <ButtonDropdown slot="trigger" variant="secondary" size="s" type="button">
          <span data-ds-dd="modal-hero-label">{defaultHeroMenuLabel}</span>
        </ButtonDropdown>
        <ShowcaseIconMenuItems dataPick="modal-hero" entries={iconVariantMenu} />
      </MenuDropdown>
    </ShowcaseControlRow>
    <ShowcaseControlRow label="Toolbar">
      <div class="ds-showcase-toggle-wrap" data-ds-toggle="modal-toolbar">
        <Toggle name="ds-modal-toolbar" checked={true} />
      </div>
    </ShowcaseControlRow>
    <ShowcaseControlRow label="Toolbar align">
      <MenuDropdown>
        <ButtonDropdown slot="trigger" variant="secondary" size="s" type="button">
          <span data-ds-dd="modal-toolbar-align-label">{toolbarAlignLabels.end}</span>
        </ButtonDropdown>
        <MenuItemAction type="button" data-ds-pick="modal-toolbar-align" data-value="start">
          {toolbarAlignLabels.start}
        </MenuItemAction>
        <MenuItemAction type="button" data-ds-pick="modal-toolbar-align" data-value="end">
          {toolbarAlignLabels.end}
        </MenuItemAction>
      </MenuDropdown>
    </ShowcaseControlRow>
    <ShowcaseControlRow label="Dismissible">
      <div class="ds-showcase-toggle-wrap" data-ds-toggle="modal-dismissible">
        <Toggle name="ds-modal-dismissible" checked={true} />
      </div>
    </ShowcaseControlRow>
  </ShowcaseControlsTable>

  <ShowcaseCopyPrompt componentLabel="ModalDialog" />
</ComponentShowcasePage>

<script is:inline define:vars={{ iconHtmlMap, defaultHeroKey }}>
  globalThis['__dsShowcaseModalIconHtmlMap'] = iconHtmlMap;
  globalThis['__dsShowcaseModalDefaultHeroKey'] = defaultHeroKey;
</script>
<script>
  import { buildCopyPrompt } from '../copy-prompt';
  import { bindFieldClear, getShowcasePage, takeInjectedIconHtmlMap } from '../showcase-ui';

  type LayoutMode = 'centered' | 'footer';

  function init() {
    const root = document.querySelector('[data-ds-demo="modal"]');
    const page = getShowcasePage(root);
    const centered = document.getElementById('demo-modal-centered') as HTMLDialogElement | null;
    const footer = document.getElementById('demo-modal-footer') as HTMLDialogElement | null;
    const openBtn = document.getElementById('ds-modal-open');
    const titleCtrl = document.getElementById('ds-modal-title') as HTMLInputElement | null;
    const descCtrl = document.getElementById('ds-modal-desc') as HTMLInputElement | null;
    const layoutLabel = page?.querySelector('[data-ds-dd="modal-layout-label"]');
    const heroLabel = page?.querySelector('[data-ds-dd="modal-hero-label"]');
    const toolbarAlignLabel = page?.querySelector('[data-ds-dd="modal-toolbar-align-label"]');
    const toolbarToggle = page?.querySelector<HTMLInputElement>(
      '[data-ds-toggle="modal-toolbar"] input[role="switch"]',
    );
    const dismissibleToggle = page?.querySelector<HTMLInputElement>(
      '[data-ds-toggle="modal-dismissible"] input[role="switch"]',
    );

    if (!page || !centered || !footer || !openBtn || !titleCtrl || !descCtrl) return;

    bindFieldClear(page);

    const map: Record<string, string> = { ...takeInjectedIconHtmlMap('__dsShowcaseModalIconHtmlMap') };
    const w = globalThis as Record<string, unknown>;
    const serverDefaultHero = w['__dsShowcaseModalDefaultHeroKey'];
    let iconKey =
      typeof serverDefaultHero === 'string' ? serverDefaultHero : 'placeholder-outline';
    let layoutMode: LayoutMode = 'centered';
    let toolbarAlign: 'start' | 'end' = 'end';

    const dialogs: HTMLDialogElement[] = [centered, footer];

    function titleEl(d: HTMLDialogElement): HTMLElement | null {
      return document.getElementById(`${d.id}-title`);
    }

    function descEl(d: HTMLDialogElement): HTMLElement | null {
      return document.getElementById(`${d.id}-description`);
    }

    function patchHero(d: HTMLDialogElement) {
      const icon = d.querySelector<HTMLElement>('.ui-modal-dialog__hero .ui-icon');
      if (!icon) return;
      icon.classList.remove('ui-icon--missing');
      const html = map[iconKey] || '';
      icon.setAttribute('data-size', 'l');
      icon.setAttribute('data-style', iconKey.endsWith('-fill') ? 'fill' : 'outline');
      icon.innerHTML = html;
    }

    function apply() {
      const t = titleCtrl.value.trim() || 'Dialog title';
      const d = descCtrl.value.trim() || 'Supporting description.';
      const heroHidden = iconKey === 'none';
      for (const dlg of dialogs) {
        const te = titleEl(dlg);
        const de = descEl(dlg);
        if (te) te.textContent = t;
        if (de) de.textContent = d;
        const hero = dlg.querySelector<HTMLElement>('.ui-modal-dialog__hero');
        if (hero) hero.hidden = heroHidden;
        if (!heroHidden) patchHero(dlg);
        const tb = dlg.querySelector<HTMLElement>('.ui-modal-dialog__toolbar');
        if (tb) {
          tb.hidden = !Boolean(toolbarToggle?.checked);
          tb.setAttribute('data-toolbar-align', toolbarAlign);
        }
        dlg.setAttribute('data-dismissible', dismissibleToggle?.checked !== false ? 'true' : 'false');
      }
      if (layoutLabel)
        layoutLabel.textContent = layoutMode === 'footer' ? 'Footer actions' : 'Centered';
      if (toolbarAlignLabel)
        toolbarAlignLabel.textContent =
          toolbarAlign === 'start' ? 'Start' : 'End';
    }

    openBtn.addEventListener('click', () => {
      const dlg = layoutMode === 'centered' ? centered : footer;
      const other = layoutMode === 'centered' ? footer : centered;
      other.close();
      dlg.show();
    });

    page.querySelectorAll('[data-ds-pick="modal-layout"]').forEach((el) => {
      el.addEventListener('click', () => {
        const v = (el as HTMLElement).dataset.value as LayoutMode | undefined;
        if (v === 'centered' || v === 'footer') {
          layoutMode = v;
          centered.close();
          footer.close();
          apply();
        }
      });
    });

    page.querySelectorAll('[data-ds-pick="modal-hero"]').forEach((el) => {
      el.addEventListener('click', () => {
        const v = (el as HTMLElement).dataset.value;
        if (!v) return;
        iconKey = v;
        const labelEl = (el as HTMLElement).querySelector('.ui-item__label');
        const labelText = (labelEl?.textContent ?? (el as HTMLElement).textContent ?? v).trim();
        if (heroLabel) heroLabel.textContent = labelText;
        apply();
      });
    });

    page.querySelectorAll('[data-ds-pick="modal-toolbar-align"]').forEach((el) => {
      el.addEventListener('click', () => {
        const v = (el as HTMLElement).dataset.value;
        if (v === 'start' || v === 'end') {
          toolbarAlign = v;
          apply();
        }
      });
    });

    toolbarToggle?.addEventListener('change', apply);
    dismissibleToggle?.addEventListener('change', apply);
    titleCtrl.addEventListener('input', apply);
    descCtrl.addEventListener('input', apply);
    apply();

    page.querySelector('.js-ds-showcase-copy')?.addEventListener('click', async () => {
      const title = titleCtrl.value.trim() || 'Dialog title';
      const description = descCtrl.value.trim() || 'Supporting description.';
      const showHero = iconKey !== 'none';
      const toolbarOn = Boolean(toolbarToggle?.checked);
      const dismissibleOn = dismissibleToggle?.checked !== false;
      const heroFile = showHero ? `icon-${iconKey}.svg` : undefined;

      const text = buildCopyPrompt({
        component: 'ModalDialog',
        props: {
          layout: layoutMode,
          dismissible: dismissibleOn,
          toolbar: toolbarOn,
          toolbarAlign,
          showHero,
          title,
          description,
          ...(showHero && heroFile ? { heroIcon: heroFile } : {}),
        },
        note:
          'Slots: toolbar (e.g. ButtonIcon with dialogClose), hero (Icon size L when showHero), title, description, center (layout centered), footer (layout footer). Hiding toolbar in the demo only toggles visibility; use toolbar={false} to omit. Hero None matches showHero={false} (omit hero slot).',
      });
      try {
        await navigator.clipboard.writeText(text);
      } catch {
        /* ignore */
      }
    });
  }

  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', init);
  else init();
</script>
