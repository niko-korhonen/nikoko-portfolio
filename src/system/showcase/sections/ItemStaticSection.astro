---
import Badge from '../../components/Badge.astro';
import ItemStatic from '../../components/ItemStatic.astro';
import Toggle from '../../components/Toggle.astro';
import Stack from '../../primitives/Stack.astro';
import ComponentShowcasePage from '../templates/ComponentShowcasePage.astro';
import ShowcasePreviewCard from '../templates/ShowcasePreviewCard.astro';
import ShowcaseControlsTable from '../templates/ShowcaseControlsTable.astro';
import ShowcaseControlRow from '../templates/ShowcaseControlRow.astro';
import ShowcaseCopyPrompt from '../templates/ShowcaseCopyPrompt.astro';
---

<ComponentShowcasePage
  title="ItemStatic"
  headingId="item-static-heading"
  description="Non-interactive list rows for settings-style summaries. Use trailing slots for badges, toggles, or values without the row stealing pointer events from nested controls."
>
  <ShowcasePreviewCard>
    <div data-ds-demo="item-static" style="width:100%;max-width:28rem;">
      <Stack gap="space-12" align="stretch">
        <ItemStatic variant="floating" description="Read-only copy" detail="Value">
          Setting name
        </ItemStatic>
        <ItemStatic variant="floating" description="Badge in trailing slot">
          Notifications
          <Badge slot="slot-end" variant="accent">3</Badge>
        </ItemStatic>
        <ItemStatic variant="inline" description="Toggle on the right">
          Wi‑Fi
          <Toggle slot="slot-end" name="demo-item-static-toggle" />
        </ItemStatic>
      </Stack>
    </div>
  </ShowcasePreviewCard>

  <ShowcaseControlsTable>
    <ShowcaseControlRow label="Usage">
      <p class="text-body-xs-plain" style="margin:0">
        Use <code class="text-code-xs-plain">description</code>, <code class="text-code-xs-plain">detail</code>, and{' '}
        <code class="text-code-xs-plain">slot-end</code> for trailing content. Variants: floating vs inline surface.
      </p>
    </ShowcaseControlRow>
  </ShowcaseControlsTable>

  <ShowcaseCopyPrompt componentLabel="ItemStatic" />
</ComponentShowcasePage>

<script>
  import { buildCopyPrompt } from '../copy-prompt';
  import { getShowcasePage } from '../showcase-ui';

  function init() {
    const page = getShowcasePage();
    if (!page) return;

    page.querySelector('.js-ds-showcase-copy')?.addEventListener('click', async () => {
      const text = buildCopyPrompt({
        component: 'ItemStatic',
        props: {
          variant: 'floating | inline',
        },
        note: 'Pass description, detail, and slot-end for badges, toggles, or values.',
      });
      try {
        await navigator.clipboard.writeText(text);
      } catch {
        /* ignore */
      }
    });
  }

  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', init);
  else init();
</script>
