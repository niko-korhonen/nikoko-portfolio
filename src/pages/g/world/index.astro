---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import AnchoredToast from '../../../system/components/AnchoredToast.astro';
import Button from '../../../system/components/Button.astro';
import ButtonDropdown from '../../../system/components/ButtonDropdown.astro';
import ButtonIcon from '../../../system/components/ButtonIcon.astro';
import MenuDropdown from '../../../system/components/MenuDropdown.astro';
import MenuItemAction from '../../../system/components/MenuItemAction.astro';
import ModalDialog from '../../../system/components/ModalDialog.astro';
import ScorePillCounter from '../../../system/components/ScorePillCounter.astro';
import TextField from '../../../system/components/TextField.astro';
import Icon from '../../../system/icons/Icon.astro';
---

<BaseLayout title="World typer — Niko UI">
  <div class="world-game">
    <div id="world-game-map" class="world-game__map" aria-label="World map"></div>

    <div class="world-game__timer">
      <Button id="world-game-timer-btn" variant="secondary" size="m" type="button" disabled>15:00</Button>
    </div>

    <div class="world-game__top-right">
      <div class="world-game-theme-menu">
        <MenuDropdown>
          <ButtonDropdown slot="trigger" variant="ghost" size="m" type="button">Theme</ButtonDropdown>
          <MenuItemAction type="button" role="menuitem" data-theme-value="system">
            <Icon slot="slot-start" name="lock" style="outline" size="s" />
            System
          </MenuItemAction>
          <MenuItemAction type="button" role="menuitem" data-theme-value="light">
            <Icon slot="slot-start" name="sun" style="outline" size="s" />
            Light
          </MenuItemAction>
          <MenuItemAction type="button" role="menuitem" data-theme-value="dark">
            <Icon slot="slot-start" name="moon" style="outline" size="s" />
            Dark
          </MenuItemAction>
        </MenuDropdown>
      </div>
      <div class="world-game__score">
        <ScorePillCounter
          id="world-game-score"
          variant="secondary"
          size="m"
          value={0}
          trailingLabel="of …"
        >
          <Icon slot="icon-start" name="trophy" style="outline" size="m" />
        </ScorePillCounter>
      </div>
    </div>

    <div id="world-game-guess-wrap" class="world-game__guess">
      <div class="world-game__guess-stack">
        <AnchoredToast
          class="world-game__guess-toast"
          variant="success"
          message="Correct"
          position="top"
          align="center"
        >
          <span slot="trigger" class="world-game__guess-toast-anchor" aria-hidden="true"></span>
        </AnchoredToast>
        <TextField
          id="world-game-guess"
          variant="filled"
          size="l"
          tone="default"
          placeholder="Guess"
          disabled={false}
          ariaLabel="Country guess"
        />
      </div>
    </div>

    <ModalDialog
      id="world-game-start-modal"
      layout="centered"
      dismissible={false}
      toolbar={true}
      toolbarAlign="end"
      showHero={true}
    >
      <ButtonIcon slot="toolbar" variant="ghost" size="m" label="Back to home" href="/">
        <Icon name="cross" style="outline" size="s" />
      </ButtonIcon>
      <Icon slot="hero" name="globe" style="fill" size="l" />
      <span slot="title">World typer</span>
      <span slot="description"
        >Type as many world countries as you can remember in 15 minutes.</span
      >
      <Button id="world-game-start-btn" slot="center" variant="primary" size="l" type="button">Start</Button>
    </ModalDialog>

    <ModalDialog
      id="world-game-pause-modal"
      layout="footer"
      dismissible={true}
      toolbar={true}
      toolbarAlign="end"
      showHero={true}
    >
      <ButtonIcon slot="toolbar" variant="ghost" size="m" label="Close dialog" dialogClose>
        <Icon name="cross" style="outline" size="s" />
      </ButtonIcon>
      <Icon slot="hero" name="pause" style="fill" size="l" />
      <span slot="title">Game paused</span>
      <span slot="description">Practice makes perfect, don’t give up!</span>
      <Button id="world-game-resume-btn" slot="footer" variant="primary" size="l" type="button">Resume</Button>
      <Button
        id="world-game-give-up-btn"
        slot="footer"
        variant="accent"
        size="l"
        type="button"
        accentContainer="container-accent-negative"
      >
        Give up
      </Button>
    </ModalDialog>

    <ModalDialog
      id="world-game-over-modal"
      layout="footer"
      dismissible={true}
      toolbar={true}
      toolbarAlign="end"
      showHero={true}
    >
      <ButtonIcon slot="toolbar" variant="ghost" size="m" label="Close dialog" dialogClose>
        <Icon name="cross" style="outline" size="s" />
      </ButtonIcon>
      <Icon slot="hero" name="trophy" style="fill" size="l" />
      <span slot="title">Game over</span>
      <span slot="description" id="world-game-over-description"></span>
      <Button slot="footer" variant="primary" size="l" type="button" dialogClose>Review map</Button>
      <Button id="world-game-over-play-again-btn" slot="footer" variant="secondary" size="l" type="button"
        >Play again</Button
      >
    </ModalDialog>
  </div>
</BaseLayout>

<script>
  import { initWorldGame } from '../../../features/world-typer/world-game-client.ts';

  const storageKey = 'niko-ui-theme';

  function applyTheme(value: 'system' | 'light' | 'dark') {
    const root = document.documentElement;
    if (value === 'system') {
      root.removeAttribute('data-theme');
      root.style.colorScheme = '';
    } else {
      root.setAttribute('data-theme', value);
      root.style.colorScheme = value;
    }
    try {
      localStorage.setItem(storageKey, value);
    } catch {
      /* ignore */
    }
  }

  document.querySelectorAll('.world-game-theme-menu [data-theme-value]').forEach((el) => {
    el.addEventListener('click', () => {
      const v = el.getAttribute('data-theme-value');
      if (v === 'light' || v === 'dark' || v === 'system') {
        applyTheme(v);
      }
    });
  });

  try {
    const saved = localStorage.getItem(storageKey);
    if (saved === 'light' || saved === 'dark' || saved === 'system') {
      applyTheme(saved);
    }
  } catch {
    /* ignore */
  }

  const mapHost = document.getElementById('world-game-map');
  const timerBtn = document.getElementById('world-game-timer-btn');
  const scorePill = document.getElementById('world-game-score');
  const guessInput = document.getElementById('world-game-guess') as HTMLInputElement | null;
  const guessWrap = document.getElementById('world-game-guess-wrap');
  const guessToastRoot = document.querySelector('#world-game-guess-wrap [data-anchored-toast]') as HTMLElement | null;
  const startModal = document.getElementById('world-game-start-modal') as HTMLDialogElement | null;
  const pauseModal = document.getElementById('world-game-pause-modal') as HTMLDialogElement | null;
  const overModal = document.getElementById('world-game-over-modal') as HTMLDialogElement | null;

  if (
    mapHost &&
    timerBtn instanceof HTMLButtonElement &&
    scorePill &&
    guessInput &&
    guessWrap &&
    guessToastRoot &&
    startModal &&
    pauseModal &&
    overModal
  ) {
    initWorldGame({
      mapHost,
      timerBtn,
      scorePill,
      guessInput,
      guessWrap,
      guessToastRoot,
      startModal,
      pauseModal,
      overModal,
    });
  }
</script>

<style is:global>
  @import '../../../features/world-typer/world-game.css';
</style>
