---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Games — Niko UI">
  <main style="padding: var(--space-16); max-width: 40rem;">
    <h1 class="text-label-l-plain" style="margin: 0 0 var(--space-8);">Creative lab games</h1>
    <p class="text-body-s-plain" style="margin: 0 0 var(--space-8); color: var(--color-content-secondary);">
      Small browser games built on the design system.
    </p>
    <ul class="text-body-s-plain" style="margin: 0; padding-left: 1.25rem;">
      <li>
        <a href="/g/world" class="text-body-s-plain" style="color: var(--color-content-link);">World typer</a>
        — type world countries on a globe.
      </li>
    </ul>
  </main>
</BaseLayout>
