---
import BaseLayout from '../layouts/BaseLayout.astro';
import ButtonIcon from '../design-system/components/ui/ButtonIcon.astro';
import { LandingBadgePhysics } from '../components/LandingBadgePhysics';
---

<BaseLayout title="Niko">
  <div class="landing-playground ds-surface-1">
    <LandingBadgePhysics client:load />
    <div class="landing-chrome">
      <div class="landing-chrome__tr">
        <ButtonIcon
          variant="ghost"
          size="m"
          icon="code-outlined"
          label="Design system"
          href="/s/"
        />
      </div>
      <div class="landing-chrome__bl">
        <p class="landing-name">
          <span class="landing-name__line">Niko</span>
          <span class="landing-name__line">Korhonen</span>
        </p>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .landing-playground {
    position: relative;
    min-height: 100dvh;
    overflow: hidden;
  }
  .landing-playground :global(canvas) {
    display: block;
    touch-action: none;
  }

  .landing-chrome {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
  }

  .landing-chrome__tr {
    position: absolute;
    top: 8px;
    right: 8px;
    pointer-events: auto;
  }

  .landing-chrome__bl {
    position: absolute;
    bottom: var(--landing-name-inset);
    left: var(--landing-name-inset);
    max-width: calc(100vw - var(--landing-name-inset) * 2);
    pointer-events: none;
  }

  .landing-playground {
    --landing-name-inset: 24px;
  }

  @media (min-width: 600px) {
    .landing-playground {
      --landing-name-inset: 48px;
    }
  }

  .landing-name {
    margin: 0;
    color: var(--foreground-primary);
  }

  .landing-name__line {
    display: block;
    font-family: var(--font-display);
    font-weight: 600;
  }

  /* S (0–599): one step more generous than headline-m; M+ unchanged */
  .landing-name__line {
    font-size: var(--type-headline-l-size);
    line-height: var(--type-headline-l-line-height);
    letter-spacing: calc(var(--type-headline-l-tracking) * 1px);
  }

  @media (min-width: 600px) {
    .landing-name__line {
      font-size: var(--type-headline-xl-size);
      line-height: var(--type-headline-xl-line-height);
      letter-spacing: calc(var(--type-headline-xl-tracking) * 1px);
    }
  }

  @media (min-width: 1024px) {
    .landing-name__line {
      font-size: var(--type-display-s-size);
      line-height: var(--type-display-s-line-height);
      letter-spacing: calc(var(--type-display-s-tracking) * 1px);
    }
  }
</style>
