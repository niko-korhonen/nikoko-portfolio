---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../system/components/Button.astro';
---

<BaseLayout>
  <main class="home">
    <h1 class="text-headline-l-plain">Niko UI</h1>
    <p class="text-body-m-plain home__muted">Creative lab — foundation only.</p>
    <p class="text-body-m-plain home__cta">
      <Button size="l" href="/system">Design system tokens</Button>
    </p>
  </main>
</BaseLayout>

<style>
  .home {
    min-height: 100vh;
    display: grid;
    place-content: center;
    gap: var(--radius-low);
    padding: var(--radius-medium);
    text-align: center;
  }

  .home__muted {
    margin: 0;
    color: var(--color-content-secondary);
  }

  .home__cta {
    margin: 0;
  }
</style>
