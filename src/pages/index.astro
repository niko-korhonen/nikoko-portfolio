---
import BaseLayout from '../layouts/BaseLayout.astro';
import AnchoredToast from '../system/components/AnchoredToast.astro';
import Button from '../system/components/Button.astro';
import ButtonIcon from '../system/components/ButtonIcon.astro';
import ModalDialog from '../system/components/ModalDialog.astro';
import SegmentControl from '../system/components/SegmentControl.astro';
import Icon from '../system/icons/Icon.astro';

const themeSegmentItems = [
  { value: 'system', icon: 'lock', iconStyle: 'outline' as const, content: 'icon' as const, ariaLabel: 'System theme' },
  { value: 'light', icon: 'sun', iconStyle: 'outline' as const, content: 'icon' as const, ariaLabel: 'Light theme' },
  { value: 'dark', icon: 'moon', iconStyle: 'outline' as const, content: 'icon' as const, ariaLabel: 'Dark theme' },
];
---

<BaseLayout title="Niko UI">
  <div class="home-shell">
    <div class="home-theme-bar">
      <SegmentControl
        class="js-theme-segment ui-nav-drawer__theme"
        semantic="radiogroup"
        size="m"
        ariaLabel="Theme"
        defaultValue="system"
        items={themeSegmentItems}
      />
    </div>

    <div id="rain-backdrop" class="rain-backdrop" aria-hidden="true"></div>

    <nav class="home-chrome" aria-label="Site">
      <Button variant="ghost" size="m" class="home-open-modal" type="button">Niko</Button>
      <ButtonIcon variant="ghost" size="m" label="Open design system showcase" href="/system">
        <Icon name="code" style="outline" size="m" />
      </ButtonIcon>
    </nav>

    <ModalDialog id="home-intro-modal" layout="centered">
      <ButtonIcon slot="toolbar" variant="ghost" size="m" label="Close dialog" dialogClose>
        <Icon name="cross" style="outline" size="s" />
      </ButtonIcon>
      <Icon slot="hero" name="handraised" style="outline" size="l" />
      <span slot="title">Hello stranger</span>
      <span slot="description"
        >If you want to chat about me or design, feel free to send me an email.</span
      >
      <AnchoredToast
        slot="center"
        class="home-copy-toast"
        variant="success"
        message="Copied to clipboard"
        position="top"
        align="center"
      >
        <Button slot="trigger" variant="primary" size="l" type="button" class="home-copy-email">Copy email</Button>
      </AnchoredToast>
    </ModalDialog>
  </div>
</BaseLayout>

<script>
  (function () {
    const storageKey = 'niko-ui-theme';

    function apply(value: 'system' | 'light' | 'dark') {
      const root = document.documentElement;
      if (value === 'system') {
        root.removeAttribute('data-theme');
        root.style.colorScheme = '';
      } else {
        root.setAttribute('data-theme', value);
        root.style.colorScheme = value;
      }
      try {
        localStorage.setItem(storageKey, value);
      } catch {
        /* ignore */
      }
    }

    document.addEventListener('segment-change', (e) => {
      const t = e.target;
      if (!(t instanceof Element) || !t.closest('.js-theme-segment')) return;
      const ev = e as CustomEvent<{ value?: string }>;
      const v = ev.detail?.value;
      if (v === 'light' || v === 'dark' || v === 'system') {
        apply(v);
      }
    });

    try {
      const saved = localStorage.getItem(storageKey);
      if (saved === 'light' || saved === 'dark' || saved === 'system') {
        apply(saved);
      }
    } catch {
      /* ignore */
    }
  })();
</script>

<script>
  import { enqueueAnchoredToast, initAnchoredToasts } from '../system/components/anchored-toast.ts';
  import { initRainBackdrop } from '../scripts/rain-backdrop';

  const rain = document.getElementById('rain-backdrop');
  if (rain) initRainBackdrop(rain);

  function setupChrome() {
    initAnchoredToasts();

    document.querySelector('.home-open-modal')?.addEventListener('click', () => {
      document.getElementById('home-intro-modal')?.showModal();
    });

    const toastRoot = document.querySelector<HTMLElement>('.home-copy-toast[data-anchored-toast]');
    document.querySelector('.home-copy-email')?.addEventListener('click', async (e) => {
      e.stopPropagation();
      try {
        await navigator.clipboard.writeText('niko@nikoko.com');
        if (toastRoot) enqueueAnchoredToast(toastRoot, 'success', 'Copied to clipboard');
      } catch {
        if (toastRoot) enqueueAnchoredToast(toastRoot, 'error', 'Could not copy');
      }
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', setupChrome, { once: true });
  } else {
    setupChrome();
  }
</script>

<style>
  :global(html) {
    height: 100%;
    overflow: hidden;
  }

  .home-shell {
    position: relative;
    box-sizing: border-box;
    min-height: 100dvh;
    height: 100dvh;
    max-height: 100dvh;
    overflow: hidden;
    background: var(--color-surface-base);
  }

  .home-theme-bar {
    position: fixed;
    top: var(--space-8);
    left: 50%;
    z-index: 11;
    transform: translateX(-50%);
    pointer-events: auto;
  }

  .rain-backdrop {
    position: fixed;
    inset: 0;
    z-index: 0;
    touch-action: none;
    overflow: hidden;
  }

  .home-chrome {
    position: fixed;
    z-index: 10;
    inset: var(--space-8) var(--space-8) auto var(--space-8);
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--space-8);
    pointer-events: none;
  }

  .home-chrome :global(.ui-btn),
  .home-chrome :global(.ui-btn-icon) {
    pointer-events: auto;
  }

  /** Toast stack lives in dialog; keep above modal panel chrome */
  :global(#home-intro-modal .home-copy-toast .ui-anchored-toast__stack) {
    z-index: 2;
  }

  /** Black pill text SVGs: read on dark surfaces only after invert */
  :global(html[data-theme="dark"] #rain-backdrop .rain-backdrop__piece--invert-dark) {
    filter: invert(1);
  }

  @media (prefers-color-scheme: dark) {
    :global(html:not([data-theme]) #rain-backdrop .rain-backdrop__piece--invert-dark) {
      filter: invert(1);
    }
  }

  :global(.rain-backdrop__piece) {
    position: fixed;
    left: 0;
    top: 0;
    opacity: 0;
    pointer-events: none;
    user-select: none;
    -webkit-user-drag: none;
    will-change: transform;
  }
</style>
