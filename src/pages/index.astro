---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getProjects } from '../lib/projects';

const projects = getProjects();
---

<BaseLayout>
  <main class="home">
    <section class="hero-logo">
      <div class="logo-container">
        <div class="theme-toggle" id="theme-toggle">
          <button class="toggle-option active" data-mode="light" aria-label="Light mode">
            <svg width="16" height="16" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M16.9976 1.35645H14.9976V5.38745H16.9976V1.35645Z" fill="currentColor"/>
              <path d="M4.93604 25.6471L6.35025 27.0614L9.2006 24.211L7.78638 22.7969L4.93604 25.6471Z" fill="currentColor"/>
              <path d="M16.9976 26.6123V30.6434H14.9976V26.6123H16.9976Z" fill="currentColor"/>
              <path d="M22.7939 7.78884L24.2081 9.20305L27.0585 6.35269L25.6443 4.93848L22.7939 7.78884Z" fill="currentColor"/>
              <path d="M26.6094 15H30.6404V17H26.6094V15Z" fill="currentColor"/>
              <path d="M24.2081 22.7969L22.7939 24.2111L25.6443 27.0614L27.0585 25.6473L24.2081 22.7969Z" fill="currentColor"/>
              <path d="M1.354 15H5.38502V17H1.354V15Z" fill="currentColor"/>
              <path d="M6.35025 4.93848L4.93604 6.35269L7.78638 9.20305L9.2006 7.78884L6.35025 4.93848Z" fill="currentColor"/>
              <path d="M10.3407 10.3431C13.4648 7.21895 18.5302 7.21895 21.6544 10.3431C24.7786 13.4673 24.7786 18.5327 21.6544 21.6568C18.5302 24.7811 13.4648 24.7811 10.3407 21.6568C7.21651 18.5327 7.21651 13.4673 10.3407 10.3431Z" fill="currentColor"/>
            </svg>
          </button>
          <button class="toggle-option" data-mode="dark" aria-label="Dark mode">
            <svg width="16" height="16" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M27.9956 15.6705C26.6323 16.6328 24.9688 17.1981 23.1733 17.1981C18.5498 17.1981 14.8018 13.4501 14.8018 8.82671C14.8018 7.03117 15.3671 5.36766 16.3294 4.00444C16.22 4.00148 16.1102 4 16 4C9.37259 4 4 9.37258 4 15.9999C4 22.6273 9.37259 28 16 28C22.6275 28 28 22.6273 28 15.9999C28 15.8898 27.9986 15.7799 27.9956 15.6705Z" fill="currentColor"/>
            </svg>
          </button>
        </div>
        <img src="/brand/niko-korhonen-text-logo.svg" alt="Niko Korhonen" class="text-logo" />
      </div>
    </section>

    <section class="intro">
      <p class="description">
        Versatile designer with taste. Solo designer at Karma from 0 to 1.5M+ users, 4 years at Klarna until IPO, and currently shaping the future of soundtracking at Epidemic Sound.
      </p>
      <div class="buttons">
        <button class="btn" id="copy-email" type="button">
          <svg width="16" height="16" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path fill-rule="evenodd" clip-rule="evenodd" d="M28 20H20V28H4V12H12V4H28V20ZM14 12H20V18H26V6H14V12Z" fill="currentColor"/>
          </svg>
          Copy email
        </button>
        <a href="https://www.linkedin.com/in/nikokorhonen95/" class="btn" target="_blank" rel="noopener">
          <svg width="16" height="16" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M28 15H26V7.41406L10.707 22.707L9.29297 21.293L24.5859 6H17V4H28V15Z" fill="currentColor"/>
            <path d="M15 8V10H6V26H22V17H24V28H4V8H15Z" fill="currentColor"/>
          </svg>
          LinkedIn
        </a>
      </div>
    </section>

    <section class="grid">
      {projects.map((project) => (
        <a href={`/p/${project.slug}`} class="card" style={`background-color: ${project.bg}`}>
          <img
            src={`/work/${project.image}`}
            alt={project.title}
            loading="lazy"
          />
        </a>
      ))}
    </section>
  </main>

  <!-- Toast -->
  <div class="toast" id="toast">Copied <span class="toast-email">niko@nikoko.co</span> to clipboard</div>
</BaseLayout>

<style is:global>
  html[data-theme-hint="dark"] .home {
    --theme-fg: #fff;
    --theme-bg: #000;
    color: #fff;
  }

  html[data-theme-hint="dark"] .home .text-logo {
    filter: invert(1);
  }

  html[data-theme-hint="dark"] .home .theme-toggle {
    background: rgba(255, 255, 255, 0.1);
  }
</style>

<script>
  const btn = document.getElementById('copy-email')!;
  const toast = document.getElementById('toast')!;
  const themeToggle = document.getElementById('theme-toggle')!;
  const homeEl = document.querySelector('.home') as HTMLElement;

  btn.addEventListener('click', async () => {
    await navigator.clipboard.writeText('niko@nikoko.co');
    toast.classList.add('visible');
    setTimeout(() => toast.classList.remove('visible'), 2400);
  });

  const isDark = document.documentElement.getAttribute('data-theme-hint') === 'dark';
  if (isDark) {
    homeEl.dataset.theme = 'dark';
    document.documentElement.style.setProperty('--bg-color', '#000');
    themeToggle.querySelector('[data-mode="light"]')!.classList.remove('active');
    themeToggle.querySelector('[data-mode="dark"]')!.classList.add('active');
  }
  document.documentElement.removeAttribute('data-theme-hint');

  requestAnimationFrame(() => {
    document.body.style.transition = 'background-color 0.3s, color 0.3s';
  });

  themeToggle.addEventListener('click', (e: Event) => {
    const target = (e.target as Element).closest('.toggle-option');
    if (!target) return;
    const mode = target.getAttribute('data-mode');
    if (!mode) return;
    themeToggle.querySelectorAll('.toggle-option').forEach(opt => opt.classList.remove('active'));
    target.classList.add('active');
    homeEl.dataset.theme = mode;
    if (mode === 'dark') {
      document.documentElement.style.setProperty('--bg-color', '#000');
      document.documentElement.style.setProperty('--text-color', '#fff');
    } else {
      document.documentElement.style.removeProperty('--bg-color');
      document.documentElement.style.removeProperty('--text-color');
    }
    sessionStorage.setItem('theme', mode);
  });
</script>

<style>
  .home {
    --theme-fg: #000;
    --theme-bg: #fff;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px 80px;
    color: var(--theme-fg);
    transition: color 0.3s;
  }

  .hero-logo {
    padding: 80px 0;
  }

  .logo-container {
    position: relative;
  }

  .text-logo {
    display: block;
    width: 100%;
    height: auto;
    transition: filter 0.3s;
  }

  .theme-toggle {
    position: absolute;
    top: 0;
    right: 0;
    z-index: 2;
    display: flex;
    gap: 2px;
    padding: 4px;
    border-radius: 9999px;
    background: rgba(0, 0, 0, 0.1);
    transition: background-color 0.3s;
  }

  .toggle-option {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 42px;
    height: 42px;
    border-radius: 50%;
    border: none;
    cursor: pointer;
    padding: 0;
    background: transparent;
    color: var(--theme-fg);
    transition: background-color 0.2s, color 0.2s;
  }

  .toggle-option.active {
    background: var(--theme-fg);
    color: var(--theme-bg);
  }

  .intro {
    margin-bottom: 64px;
    max-width: 50%;
  }

  .description {
    font-size: 26px;
    font-weight: 600;
    line-height: 1.385;
    margin: 0 0 32px;
    letter-spacing: -0.02em;
  }

  .buttons {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 16px 20px;
    border-radius: 9999px;
    font-size: 0.9375rem;
    font-weight: 600;
    font-family: inherit;
    text-decoration: none;
    cursor: pointer;
    border: none;
    transition: opacity 0.15s, background-color 0.3s, color 0.3s;
    background: var(--theme-fg);
    color: var(--theme-bg);
  }

  .btn:hover {
    opacity: 0.75;
  }

  .btn svg {
    flex-shrink: 0;
  }

  .grid {
    column-count: 4;
    column-gap: 12px;
  }

  .card {
    display: inline-block;
    width: 100%;
    margin-bottom: 12px;
    break-inside: avoid;
    border-radius: 24px;
    overflow: hidden;
    text-decoration: none;
    transition: transform 0.2s, box-shadow 0.2s;
    transform: translateY(0) translateZ(0);
    -webkit-backface-visibility: hidden;
    backface-visibility: hidden;
  }

  .card:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
  }

  .card img {
    display: block;
    width: 100%;
    height: auto;
    object-fit: contain;
  }

  /* Dark mode */
  .home[data-theme="dark"] {
    --theme-fg: #fff;
    --theme-bg: #000;
  }

  .home[data-theme="dark"] .text-logo {
    filter: invert(1);
  }

  .home[data-theme="dark"] .theme-toggle {
    background: rgba(255, 255, 255, 0.1);
  }

  /* Toast */
  .toast {
    position: fixed;
    bottom: 32px;
    left: 50%;
    transform: translateX(-50%) translateY(16px);
    background: #000;
    color: #fff;
    padding: 10px 20px;
    border-radius: 9999px;
    font-size: 0.875rem;
    font-weight: 600;
    white-space: nowrap;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.25s, transform 0.25s;
    z-index: 100;
  }

  .toast-email {
    color: #8E82FF;
  }

  .toast.visible {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }

  @media (max-width: 1024px) {
    .grid {
      column-count: 3;
    }
  }

  @media (max-width: 768px) {
    .intro {
      max-width: 100%;
    }
  }

  @media (max-width: 480px) {
    .home {
      padding: 0 16px 60px;
    }

    .hero-logo {
      padding: 40px 0;
    }

    .buttons {
      flex-wrap: nowrap;
    }

    .btn {
      flex: 1;
      justify-content: center;
    }

    .grid {
      column-count: 2;
    }
  }

  @media (max-width: 320px) {
    .buttons {
      flex-direction: column;
    }
  }
</style>
