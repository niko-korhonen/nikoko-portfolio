---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getProjects } from '../lib/projects';

const projects = getProjects();
---

<BaseLayout>
  <main class="home">
    <section class="hero-logo">
      <img src="/brand/niko-korhonen-text-logo.svg" alt="Niko Korhonen" class="text-logo" />
    </section>

    <section class="intro">
      <p class="description">
        Versatile designer with taste. Solo designer at Karma from 0 to 1.5M+ users, 4 years at Klarna until IPO, and currently shaping the future of soundtracking at Epidemic Sound.
      </p>
      <div class="buttons">
        <button class="btn" id="copy-email" type="button">
          <svg width="16" height="16" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path fill-rule="evenodd" clip-rule="evenodd" d="M28 20H20V28H4V12H12V4H28V20ZM14 12H20V18H26V6H14V12Z" fill="currentColor"/>
          </svg>
          Copy email
        </button>
        <a href="https://www.linkedin.com/in/nikokorhonen95/" class="btn" target="_blank" rel="noopener">
          <svg width="16" height="16" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M28 15H26V7.41406L10.707 22.707L9.29297 21.293L24.5859 6H17V4H28V15Z" fill="currentColor"/>
            <path d="M15 8V10H6V26H22V17H24V28H4V8H15Z" fill="currentColor"/>
          </svg>
          LinkedIn
        </a>
      </div>
    </section>

    <section class="grid">
      {projects.map((project) => (
        <a href={`/p/${project.slug}`} class="card" style={`background-color: ${project.bg}`}>
          <img
            src={`/work/${project.image}`}
            alt={project.title}
            loading="lazy"
          />
        </a>
      ))}
    </section>
  </main>

  <!-- Toast -->
  <div class="toast" id="toast">niko@nikoko.co copied to clipboard</div>
</BaseLayout>

<script>
  const btn = document.getElementById('copy-email')!;
  const toast = document.getElementById('toast')!;

  btn.addEventListener('click', async () => {
    await navigator.clipboard.writeText('niko@nikoko.co');
    toast.classList.add('visible');
    setTimeout(() => toast.classList.remove('visible'), 2400);
  });
</script>

<style>
  .home {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px 80px;
  }

  .hero-logo {
    padding: 80px 0;
  }

  .text-logo {
    display: block;
    width: 100%;
    height: auto;
  }

  .intro {
    margin-bottom: 64px;
    max-width: 50%;
  }

  .description {
    font-size: 26px;
    font-weight: 600;
    line-height: 1.385;
    margin: 0 0 32px;
    letter-spacing: -0.02em;
  }

  .buttons {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 16px 20px;
    border-radius: 9999px;
    font-size: 0.9375rem;
    font-weight: 600;
    font-family: inherit;
    text-decoration: none;
    cursor: pointer;
    border: none;
    transition: opacity 0.15s;
    background: #000;
    color: #fff;
  }

  .btn:hover {
    opacity: 0.75;
  }

  .btn svg {
    flex-shrink: 0;
  }

  .grid {
    column-count: 4;
    column-gap: 12px;
  }

  .card {
    display: inline-block;
    width: 100%;
    margin-bottom: 12px;
    break-inside: avoid;
    border-radius: 24px;
    overflow: hidden;
    text-decoration: none;
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .card:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
  }

  .card img {
    display: block;
    width: 100%;
    height: auto;
    object-fit: contain;
  }

  /* Toast */
  .toast {
    position: fixed;
    bottom: 32px;
    left: 50%;
    transform: translateX(-50%) translateY(16px);
    background: #000;
    color: #fff;
    padding: 10px 20px;
    border-radius: 9999px;
    font-size: 0.875rem;
    font-weight: 600;
    white-space: nowrap;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.25s, transform 0.25s;
    z-index: 100;
  }

  .toast.visible {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }

  @media (max-width: 1024px) {
    .grid {
      column-count: 3;
    }
  }

  @media (max-width: 768px) {
    .intro {
      max-width: 100%;
    }
  }

  @media (max-width: 480px) {
    .home {
      padding: 0 16px 60px;
    }

    .hero-logo {
      padding: 40px 0;
    }

    .buttons {
      flex-wrap: nowrap;
    }

    .btn {
      flex: 1;
      justify-content: center;
    }

    .grid {
      column-count: 2;
    }
  }

  @media (max-width: 320px) {
    .buttons {
      flex-direction: column;
    }
  }
</style>
