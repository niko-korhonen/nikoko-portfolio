---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getProjects, getProjectBySlug } from '../../lib/projects';

export function getStaticPaths() {
  return getProjects().map((p) => ({
    params: { slug: p.slug },
  }));
}

const { slug } = Astro.params;
const project = getProjectBySlug(slug!);

if (!project) {
  return Astro.redirect('/');
}
---

<BaseLayout>
  <div class="project-page">
    <a href="/" class="company-logo">
      <img src={`/companies/${project.logo}.png`} alt={project.logo} />
    </a>

    <a href="/" class="close-btn" aria-label="Close">
      <svg width="20" height="20" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M24.707 8.70703L17.4141 16L24.707 23.293L23.293 24.707L16 17.4141L8.70703 24.707L7.29297 23.293L14.5859 16L7.29297 8.70703L8.70703 7.29297L16 14.5859L23.293 7.29297L24.707 8.70703Z" fill="white"/>
      </svg>
    </a>

    <section class="stage" style={`background-color: ${project.bg}`}>
      <img
        class="stage-image"
        src={`/work/${project.image}`}
        alt={project.title}
      />
    </section>

    <section class="content">
      <h1>{project.title}</h1>
      <p>{project.description}</p>
    </section>
  </div>
</BaseLayout>

<style>
  .project-page {
    position: relative;
  }

  .company-logo {
    position: fixed;
    top: 16px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 10;
    text-decoration: none;
  }

  .company-logo img {
    max-height: 40px;
    width: auto;
    display: block;
  }

  .close-btn {
    position: fixed;
    top: 16px;
    right: 16px;
    z-index: 10;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: #000;
    text-decoration: none;
    transition: opacity 0.15s;
  }

  .close-btn:hover {
    opacity: 0.75;
  }

  .stage {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 20px;
    box-sizing: border-box;
  }

  .stage-image {
    max-width: calc(100vw - 40px);
    max-height: calc(100vh - 40px);
    object-fit: contain;
    display: block;
  }

  .content {
    background: #ffffff;
    max-width: 1200px;
    margin: 0 auto;
    padding: 64px 24px 80px;
  }

  .content h1 {
    font-size: 54px;
    font-weight: 600;
    line-height: 1.15;
    letter-spacing: -0.02em;
    margin: 0 0 16px;
  }

  .content p {
    font-size: 54px;
    font-weight: 400;
    line-height: 1.15;
    letter-spacing: -0.02em;
    margin: 0;
    color: #555;
  }

  @media (max-width: 480px) {
    .content {
      padding: 40px 16px 60px;
    }

    .content h1 {
      font-size: 28px;
    }

    .content p {
      font-size: 28px;
    }
  }
</style>
