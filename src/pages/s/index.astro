---
import ShowcaseLayout from '../../layouts/ShowcaseLayout.astro';
---

<ShowcaseLayout
  title="Intro"
  description="This design system is under active construction and is very much incomplete. I'm actively building this myself with Figma and Cursor, learning as I go. Feel free to look around and come back later to see how it develops. Best regards, Niko Korhonen."
>
  <div slot="demo">
    <p class="ds-type-body-xl-tall">
      Use the table of contents to browse primitives and components. The rail (desktop) and bottom bar (mobile) reuse the same navigation data from
      <code class="ds-type-code-xl-tall">navigation.ts</code>.
    </p>
  </div>
</ShowcaseLayout>
