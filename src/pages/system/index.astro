  <script>
    (function () {
      const label = document.getElementById('theme-mode-label');
      const storageKey = 'niko-ui-theme';

      const themeLabels = {
        system: 'System',
        light: 'Light',
        dark: 'Dark',
      };

      function apply(value) {
        const root = document.documentElement;
        if (value === 'system') {
          root.removeAttribute('data-theme');
        } else {
          root.setAttribute('data-theme', value);
        }
        try {
          localStorage.setItem(storageKey, value);
        } catch {
          /* ignore */
        }
        if (label) {
          label.textContent = themeLabels[value] ?? 'System';
        }
      }

      try {
        const saved = localStorage.getItem(storageKey);
        if (saved === 'light' || saved === 'dark' || saved === 'system') {
          apply(saved);
        }
      } catch {
        /* ignore */
      }

      document.querySelectorAll('.js-theme-option').forEach((btn) => {
        btn.addEventListener('click', () => {
          const v = btn.getAttribute('data-theme-value');
          if (v === 'light' || v === 'dark' || v === 'system') {
            apply(v);
          }
        });
      });
    })();
  </script>

  <script is:inline>
    (function () {
      const grid = document.getElementById('icon-grid-all');
      if (!grid) return;

      function applyIconSize(btn) {
        let size = 'l';
        if (btn.classList.contains('icon-size--xs')) size = 'xs';
        else if (btn.classList.contains('icon-size--l')) size = 'l';
        else if (btn.classList.contains('icon-size--m')) size = 'm';
        else if (btn.classList.contains('icon-size--s')) size = 's';
        grid.querySelectorAll('.ui-icon').forEach((el) => {
          el.setAttribute('data-size', size);
        });
      }

      document.querySelectorAll('.js-icon-size-option').forEach((btn) => {
        btn.addEventListener('click', () => applyIconSize(btn));
      });
    })();
  </script>
