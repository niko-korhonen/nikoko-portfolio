---
interface Props {
  gap?: string;
  align?: 'start' | 'center' | 'end' | 'stretch';
  justify?: 'start' | 'center' | 'end' | 'space-between';
  wrap?: boolean;
  class?: string;
}
const {
  gap = '8',
  align = 'stretch',
  justify = 'start',
  wrap = false,
  class: className = '',
} = Astro.props;
const style = `--ds-inline-gap: var(--spacing-${gap});`;
---
<div
  class:list={[
    'ds-inline',
    `ds-inline--align-${align}`,
    `ds-inline--justify-${justify}`,
    wrap && 'ds-inline--wrap',
    className,
  ]}
  style={style}
>
  <slot />
</div>
