---
import DsGrid from '../../components/primitives/Grid.astro';
---

<DsGrid columns="repeat(3, 1fr)" gap="12">
  <div
    class="ds-type-code-m-tall"
    style="padding: var(--spacing-16); background: var(--surface-3); border-radius: var(--radius-s); color: var(--foreground-secondary);"
  >
    A
  </div>
  <div
    class="ds-type-code-m-tall"
    style="padding: var(--spacing-16); background: var(--surface-3); border-radius: var(--radius-s); color: var(--foreground-secondary);"
  >
    B
  </div>
  <div
    class="ds-type-code-m-tall"
    style="padding: var(--spacing-16); background: var(--surface-3); border-radius: var(--radius-s); color: var(--foreground-secondary);"
  >
    C
  </div>
</DsGrid>
