---
import DsStack from '../../components/primitives/Stack.astro';
---

<DsStack gap="12" align="stretch">
  <div
    class="ds-type-code-m-tall"
    style="padding: var(--spacing-12); background: var(--surface-3); border-radius: var(--radius-s); color: var(--foreground-secondary);"
  >
    One
  </div>
  <div
    class="ds-type-code-m-tall"
    style="padding: var(--spacing-12); background: var(--surface-3); border-radius: var(--radius-s); color: var(--foreground-secondary);"
  >
    Two
  </div>
  <div
    class="ds-type-code-m-tall"
    style="padding: var(--spacing-12); background: var(--surface-3); border-radius: var(--radius-s); color: var(--foreground-secondary);"
  >
    Three
  </div>
</DsStack>
