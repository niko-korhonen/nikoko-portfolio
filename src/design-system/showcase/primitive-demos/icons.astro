---
import fs from 'node:fs';
import path from 'node:path';
import Icon from '../../components/media/Icon.astro';
import DsGrid from '../../components/primitives/Grid.astro';
import Stack from '../../components/primitives/Stack.astro';

const iconsDir = path.join(process.cwd(), 'public/icons');
const iconNames = fs
  .readdirSync(iconsDir)
  .filter((f) => f.endsWith('.svg'))
  .map((f) => f.replace(/\.svg$/, ''))
  .sort((a, b) => a.localeCompare(b));
---

<Stack gap="16">
  <p class="ds-type-code-m-tall" style="color: var(--foreground-secondary);">
    SVG assets in <code>/public/icons</code>, referenced via the Icon component or <code>--icon-src</code> mask. Sizes:
    <code>xxl</code> through <code>s</code> (see <code>--icon-*</code> tokens).
  </p>
  <p class="ds-type-code-m-tall" style="color: var(--foreground-secondary);">
    {iconNames.length} icons
  </p>
  <DsGrid columns="repeat(auto-fill, minmax(7.5rem, 1fr))" gap="12">
    {
      iconNames.map((name) => (
        <div class="ds-showcase-icon-cell">
          <Icon name={name} size="l" />
          <span class="ds-type-code-m-tall" style="color: var(--foreground-secondary); word-break: break-word;">
            {name}
          </span>
        </div>
      ))
    }
  </DsGrid>
</Stack>
