---
import Stack from '../../components/primitives/Stack.astro';
import Inline from '../../components/primitives/Inline.astro';
import { spacingScaleKeys } from '../../lib/showcase-demos-data';
---

<Stack gap="16">
  <p class="ds-type-code-m-tall" style="color: var(--foreground-secondary);">
    Density spacing scale — use <code>--spacing-*</code> for gaps, padding, and layout rhythm.
  </p>
  <Stack gap="6">
    {
      spacingScaleKeys.map((s) => (
        <Inline gap="12" align="center">
          <code class="ds-type-code-m-tall" style="width: 8rem; flex-shrink: 0;">
            --spacing-{s}
          </code>
          <div
            style={`width: var(--spacing-${s}); height: var(--spacing-16); background: var(--foreground-primary); border-radius: var(--radius-xs); flex-shrink: 0;`}
            aria-hidden="true"
          />
        </Inline>
      ))
    }
  </Stack>
</Stack>
