---
import Stack from '../../components/primitives/Stack.astro';
import { ButtonDropdownDemo } from './ButtonDropdownDemo';
---

<Stack gap="12">
  <p class="ds-type-body-l-tall" style="color: var(--foreground-secondary);">
    Same padding, typography, and variants as Button, with a fixed trailing chevron-down. Opening the menu applies the selected interactive token for each variant until the menu closes.
  </p>
  <ButtonDropdownDemo client:load />
</Stack>
