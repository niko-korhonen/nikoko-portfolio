---
import Stack from '../../components/primitives/Stack.astro';
import Inline from '../../components/primitives/Inline.astro';
import Button from '../../components/ui/Button.astro';
---

<Stack gap="24">
  <p class="ds-type-label-l-short" style="color: var(--foreground-secondary);">Sizes</p>
  <Inline gap="8" wrap align="center">
    <Button variant="fill" size="l">Label L</Button>
    <Button variant="fill" size="m">Label M</Button>
    <Button variant="fill" size="s">Label S</Button>
  </Inline>
  <p class="ds-type-label-l-short" style="color: var(--foreground-secondary);">Variants</p>
  <Inline gap="8" wrap align="center">
    <Button variant="fill" size="m">Fill</Button>
    <Button variant="outline" size="m">Outline</Button>
    <Button variant="subtle" size="m">Subtle</Button>
    <Button variant="ghost" size="m">Ghost</Button>
    <span style="display: inline-flex; padding: var(--spacing-8); background: var(--surface-inverse); border-radius: var(--radius-m);">
      <Button variant="ghost-inverse" size="m">Ghost inv.</Button>
    </span>
  </Inline>
  <Inline gap="8" wrap align="center">
    <Button variant="fill" size="m" leadingIcon="search-outlined">Leading</Button>
    <Button variant="outline" size="m" trailingIcon="chevron-right-outlined">Trailing</Button>
    <Button variant="fill" size="m" disabled>Disabled</Button>
  </Inline>
</Stack>
