---
import { ButtonPlayground } from './playgrounds/ButtonPlayground';
import { ButtonDropdownPlayground } from './playgrounds/ButtonDropdownPlayground';
import { ButtonIconPlayground } from './playgrounds/ButtonIconPlayground';
import { TooltipPlayground } from './playgrounds/TooltipPlayground';
import { TogglePlayground } from './playgrounds/TogglePlayground';
import { RadioPlayground } from './playgrounds/RadioPlayground';
import { ItemRowActionPlayground } from './playgrounds/ItemRowActionPlayground';
import { ItemRowStaticPlayground } from './playgrounds/ItemRowStaticPlayground';
import { ItemRowDividerPlayground } from './playgrounds/ItemRowDividerPlayground';
import { ItemRowHeaderPlayground } from './playgrounds/ItemRowHeaderPlayground';
import { MenuDropdownPlayground } from './playgrounds/MenuDropdownPlayground';
import { DialogPlayground } from './playgrounds/DialogPlayground';
import type { ComponentSlug } from '../lib/navigation';

interface Props {
  slug: ComponentSlug;
}

const { slug } = Astro.props;
---

{slug === 'button' && <ButtonPlayground client:load />}
{slug === 'button-dropdown' && <ButtonDropdownPlayground client:load />}
{slug === 'button-icon' && <ButtonIconPlayground client:load />}
{slug === 'tooltip' && <TooltipPlayground client:load />}
{slug === 'toggle' && <TogglePlayground client:load />}
{slug === 'radio' && <RadioPlayground client:load />}
{slug === 'item-row-action' && <ItemRowActionPlayground client:load />}
{slug === 'item-row-static' && <ItemRowStaticPlayground client:load />}
{slug === 'item-row-divider' && <ItemRowDividerPlayground client:load />}
{slug === 'item-row-header' && <ItemRowHeaderPlayground client:load />}
{slug === 'menu-dropdown' && <MenuDropdownPlayground client:load />}
{slug === 'dialog' && <DialogPlayground client:load />}
